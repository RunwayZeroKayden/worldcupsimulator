def get_player_data(p_record, apply_modifiers=False):
    if isinstance(p_record, tuple):
        if len(p_record) >= 3: name, base_rating = p_record[0], p_record[2]
        elif len(p_record) == 2: name, base_rating = p_record[0], p_record[1]
        else: name, base_rating = p_record[0], 75
    else:
        name, base_rating = str(p_record), 75

    if apply_modifiers and name in active_form_modifiers:
        return name, base_rating + active_form_modifiers[name]["mod"]
    return name, base_rating

def get_starting_xi(team, ignore_status=False):
    if team not in REAL_SQUADS: return []
    available = {"GK": [], "DF": [], "MF": [], "AT": []}

    for pos, players in REAL_SQUADS[team].items():
        for p in players:
            name, rating = get_player_data(p, apply_modifiers=not ignore_status)
            if not ignore_status:
                if player_status_injured.get(name, {}).get("matches", 0) > 0: continue
                if team_suspensions.get(name, {}).get("matches", 0) > 0: continue
            available[pos].append((name, rating, pos))
        available[pos].sort(key=lambda x: x[1], reverse=True)

    xi = []
    if available["GK"]: xi.append(available["GK"].pop(0))

    for pos, count in [("DF", 3), ("MF", 3), ("AT", 2)]:
        for _ in range(count):
            if available[pos]: xi.append(available[pos].pop(0))

    pool = available["DF"] + available["MF"] + available["AT"]
    pool.sort(key=lambda x: x[1], reverse=True)

    counts = {"DF": 3, "MF": 3, "AT": 2}
    max_counts = {"DF": 5, "MF": 5, "AT": 3}

    for p in pool:
        if len(xi) >= 11: break
        if counts[p[2]] < max_counts[p[2]]:
            xi.append(p)
            counts[p[2]] += 1

    return xi

def get_xi_positional_ratings(team, ignore_status=False):
    xi = get_starting_xi(team, ignore_status)
    pos_sums = {"GK": 0, "DF": 0, "MF": 0, "AT": 0}
    for p in xi:
        pos_sums[p[2]] += p[1]
    return pos_sums

def get_active_player(team, position):
    xi = get_starting_xi(team, ignore_status=False)
    pos_players = [p for p in xi if p[2] == position]
    if pos_players:
        return random.choice(pos_players)
    return (f"{FIFA_CODES.get(team, team)} #{random.randint(2, 23)}", 75, position)

def calculate_timeline_metrics(team, abbr, is_t1=True):
    # Ensure unavailable players are properly filtered out before kickoff
    xi_raw = get_starting_xi(team, ignore_status=False)
    xi = [list(p) for p in xi_raw]
    bench = []
    active_names = [p[0] for p in xi]

    for pos, players in REAL_SQUADS.get(team, {}).items():
        for p in players:
            p_data = get_player_data(p)
            if p_data[0] not in active_names:
                bench.append([p_data[0], p_data[1], pos])
    bench.sort(key=lambda x: x[1], reverse=True)

    curr_off = sum([p[1] for p in xi if p[2] in ["MF", "AT"]])
    curr_def = sum([p[1] for p in xi if p[2] in ["GK", "DF"]])

    off_integral = curr_off * 90.0
    def_integral = curr_def * 90.0

    subs_used = 0
    incidents = {"rc": False, "inj": False}
    local_events = []
    suspended_players = []
    injured_players = []

    # 1. Red Card Engine
    if random.random() < 0.035 and xi:
        candidates = [p for p in xi if p[2] != "GK"]
        if candidates:
            victim = random.choice(candidates)
            rc_min = random.randint(15, 85)
            incidents["rc"] = True
            suspended_players.append(victim[0])

            if victim[2] in ["MF", "AT"]:
                off_integral -= victim[1] * (90 - rc_min)
            else:
                def_integral -= victim[1] * (90 - rc_min)

            off_integral -= (curr_off * 0.1) * (90 - rc_min)
            def_integral -= (curr_def * 0.1) * (90 - rc_min)

            local_events.append((rc_min, f"🟥 {rc_min}' Red Card: <b>{victim[0]}</b> ({abbr}) sent off!"))
            xi = [p for p in xi if p[0] != victim[0]]

    # 2. Injury Engine
    if random.random() < 0.045 and xi:
        victim = random.choice(xi)
        inj_min = random.randint(10, 80)
        incidents["inj"] = True
        injured_players.append(victim[0])

        if subs_used < 5:
            available_bench = [b for b in bench if b[2] == victim[2]]
            if not available_bench and victim[2] != "GK":
                 available_bench = [b for b in bench if b[2] != "GK"]

            if available_bench:
                sub = available_bench[0]
                bench.remove(sub)
                subs_used += 1

                rating_diff = victim[1] - sub[1]
                if victim[2] in ["MF", "AT"]:
                    off_integral -= rating_diff * (90 - inj_min)
                else:
                    def_integral -= rating_diff * (90 - inj_min)

                local_events.append((inj_min, f"🚑 {inj_min}' Injury: <b>{victim[0]}</b> replaced by {sub[0]}."))
                xi = [p for p in xi if p[0] != victim[0]] + [sub]
            else:
                local_events.append((inj_min, f"🚑 {inj_min}' Injury: <b>{victim[0]}</b> forced off!"))
                if victim[2] in ["MF", "AT"]:
                    off_integral -= victim[1] * (90 - inj_min)
                else:
                    def_integral -= victim[1] * (90 - inj_min)

    # 3. Tactical Substitutions
    num_tactical_subs = random.randint(3, 5 - subs_used)
    for _ in range(num_tactical_subs):
        if not xi or not bench: break
        sub_min = random.randint(60, 85)
        candidates = [p for p in xi if p[2] != "GK"]
        if not candidates: break
        out_p = random.choice(candidates)

        available_bench = [b for b in bench if b[2] == out_p[2]]
        if not available_bench:
             available_bench = [b for b in bench if b[2] != "GK"]

        if available_bench:
            in_p = available_bench[0]
            bench.remove(in_p)
            subs_used += 1

            rating_diff = out_p[1] - in_p[1]
            if out_p[2] in ["MF", "AT"]:
                off_integral -= rating_diff * (90 - sub_min)
            else:
                def_integral -= rating_diff * (90 - sub_min)

            local_events.append((sub_min, f"🔄 {sub_min}' Sub: <b>{in_p[0]}</b> on for {out_p[0]}."))
            xi = [p for p in xi if p[0] != out_p[0]] + [in_p]

    avg_off = off_integral / 90.0
    avg_def = def_integral / 90.0

    return avg_off, avg_def, incidents, local_events, suspended_players, injured_players

def simulate_match(t1, t2, can_draw=True, is_group=False, group_id=None):
    abbr1, abbr2 = FIFA_CODES.get(t1, t1), FIFA_CODES.get(t2, t2)
    match_key = f"{abbr1}-{abbr2}"

    if is_group and group_id in LIVE_RESULTS and match_key in LIVE_RESULTS[group_id]:
        g1, g2 = LIVE_RESULTS[group_id][match_key]
        actual_winner = t1 if g1 > g2 else (t2 if g2 > g1 else "Draw")
        return (3, 0) if g1 > g2 else ((1, 1) if g1 == g2 else (0, 3)), actual_winner, g1, g2, "", {}

    # RECORD XI BEFORE KICKOFF SO SNAPSHOTS REFLECT REALITY
    t1_starting_xi = get_starting_xi(t1, ignore_status=False)
    t2_starting_xi = get_starting_xi(t2, ignore_status=False)

    off1, def1, inc1, ev1, susp1, inj1 = calculate_timeline_metrics(t1, abbr1, True)
    off2, def2, inc2, ev2, susp2, inj2 = calculate_timeline_metrics(t2, abbr2, False)

    base1 = TEAM_METRICS.get(t1, {"ELO": 1500, "PELE": 1500})
    r1 = (base1["ELO"] + base1["PELE"]) / 2 + HOST_ADVANTAGE.get(t1, 0)
    base2 = TEAM_METRICS.get(t2, {"ELO": 1500, "PELE": 1500})
    r2 = (base2["ELO"] + base2["PELE"]) / 2 + HOST_ADVANTAGE.get(t2, 0)

    # DECREMENT EXISTING EXPIRED SUSPENSIONS/INJURIES
    for p, status in list(team_suspensions.items()):
        if status["team"] in [t1, t2] and status["matches"] > 0:
            status["matches"] -= 1
            if status["matches"] <= 0: del team_suspensions[p]

    for p, status in list(player_status_injured.items()):
        if status["team"] in [t1, t2] and status["matches"] > 0:
            status["matches"] -= 1
            if status["matches"] <= 0: del player_status_injured[p]

    # APPLY NEW INCIDENTS FOR FUTURE MATCHES
    for p in susp1: team_suspensions[p] = {"team": t1, "matches": 1}
    for p in susp2: team_suspensions[p] = {"team": t2, "matches": 1}
    for p in inj1: player_status_injured[p] = {"team": t1, "matches": random.choice([1, 2, 99])}
    for p in inj2: player_status_injured[p] = {"team": t2, "matches": random.choice([1, 2, 99])}

    incidents = {
        "rc1": inc1["rc"], "rc2": inc2["rc"],
        "inj1": inc1["inj"], "inj2": inc2["inj"],
        "op1": False, "op2": False, "up1": False, "up2": False
    }

    local_events = ev1 + ev2

    for p_name, data in list(active_form_modifiers.items()):
        t_name = data["team"]
        if player_status_injured.get(p_name, {}).get("matches", 0) == 0 and team_suspensions.get(p_name, {}).get("matches", 0) == 0:
            if t_name == t1:
                if data["mod"] > 0: incidents["op1"] = True
                else: incidents["up1"] = True
            elif t_name == t2:
                if data["mod"] > 0: incidents["op2"] = True
                else: incidents["up2"] = True

    if len(active_form_modifiers) < 8 and random.random() < 0.15:
        trigger_team = t1 if random.random() < 0.50 else t2
        pos_choice = random.choice(["GK", "DF", "MF", "AT"])
        p_name, p_rating, _ = get_active_player(trigger_team, pos_choice)

        if p_name not in active_form_modifiers and player_status_injured.get(p_name, {}).get("matches", 0) == 0:
            if random.random() < 0.50:
                mod = min(10, max(1, int(random.gauss(5.5, 2))))
                active_form_modifiers[p_name] = {"team": trigger_team, "pos": pos_choice, "mod": mod, "base": p_rating}
                if trigger_team == t1: incidents["op1"] = True
                else: incidents["op2"] = True
                local_events.append((5, f"🔥 <b>PEAK FORM</b>: {p_name} <b>[{p_rating} to {p_rating+mod}]</b> catches fire!"))
            else:
                mod = max(-10, min(-1, int(random.gauss(-5.5, 2))))
                active_form_modifiers[p_name] = {"team": trigger_team, "pos": pos_choice, "mod": mod, "base": p_rating}
                if trigger_team == t1: incidents["up1"] = True
                else: incidents["up2"] = True
                local_events.append((5, f"🧊 <b>POOR FORM</b>: {p_name} <b>[{p_rating} to {p_rating+mod}]</b> is struggling."))

    raw_delta = r1 - r2
    upset_factor = max(0.4, min(1.6, 1.0 + (raw_delta / 800.0)))

    lineup_offence_modifier_t1 = (off1 / def2) * form_off_factor.get(t1, 1.0)
    lineup_offence_modifier_t2 = (off2 / def1) * form_off_factor.get(t2, 1.0)

    lam1 = 1.1 * upset_factor * lineup_offence_modifier_t1
    lam2 = 1.1 * (2.0 - upset_factor) * lineup_offence_modifier_t2

    g1 = poisson(max(0.05, lam1))
    g2 = poisson(max(0.05, lam2))

    actual_winner = t1 if g1 > g2 else (t2 if g2 > g1 else "Draw")
    extra_str = ""

    if not can_draw and g1 == g2:
        g1_et, g2_et = poisson(lam1 * 0.3), poisson(lam2 * 0.3)
        if g1_et != g2_et:
            g1 += g1_et; g2 += g2_et
            actual_winner = t1 if g1 > g2 else t2
            extra_str = " (AET)"
        else:
            actual_winner = t1 if random.random() < (0.50 + (raw_delta * 0.0005)) else t2
            winner_pens = random.randint(3, 5)
            loser_pens = random.randint(0, winner_pens - 1)
            if actual_winner == t1:
                extra_str = f" ({winner_pens}-{loser_pens} Pens)"
            else:
                extra_str = f" ({loser_pens}-{winner_pens} Pens)"

    global match_snapshots
    if 'match_snapshots' not in globals(): match_snapshots = {}

    match_snapshots[match_key] = {
        "t1_name": t1, "t2_name": t2,
        "t1_xi": t1_starting_xi,
        "t2_xi": t2_starting_xi,
        "t1_rc": susp1, "t2_rc": susp2,  # Captures incidents IN this match
        "t1_inj": inj1, "t2_inj": inj2,
        "score": f"{g1} - {g2}{extra_str}",
        "incidents": incidents.copy()
    }

    if local_events:
        local_events.sort(key=lambda x: x[0])
        match_events_archive.extend([f"<b>[{abbr1} vs {abbr2}]</b> " + e[1] for e in local_events])

    we1 = 1 / (1 + 10**((-raw_delta)/400))
    w1 = 1 if actual_winner == t1 else (0 if actual_winner == t2 else 0.5)
    g_mult = 1.0 if abs(g1-g2) <= 1 else (1.5 if abs(g1-g2) == 2 else 2.0)

    performance = (w1 - we1) * g_mult
    form_off_factor[t1] = max(0.6, min(1.4, form_off_factor.get(t1, 1.0) + performance * 0.04))
    form_def_factor[t1] = max(0.6, min(1.4, form_def_factor.get(t1, 1.0) - performance * 0.04))
    form_off_factor[t2] = max(0.6, min(1.4, form_off_factor.get(t2, 1.0) - performance * 0.04))
    form_def_factor[t2] = max(0.6, min(1.4, form_def_factor.get(t2, 1.0) + performance * 0.04))

    if is_group and group_id:
        icon_str_l = "".join([ico for ico, cond in [("🟥", incidents["rc1"]), ("🚑", incidents["inj1"]), ("🔥", incidents["op1"]), ("🧊", incidents["up1"])] if cond])
        icon_str_r = "".join([ico for ico, cond in [("🟥", incidents["rc2"]), ("🚑", incidents["inj2"]), ("🔥", incidents["op2"]), ("🧊", incidents["up2"])] if cond])

        t1_html = f"<span class='m-name'>{abbr1}</span> <span class='m-flag'>{get_flag(t1)}</span>"
        t2_html = f"<span class='m-flag'>{get_flag(t2)}</span> <span class='m-name'>{abbr2}</span>"
        group_match_logs[group_id].append(
            f"<div class='m-row'>"
            f"<div class='match-events' style='display:inline-block; width:25px; text-align:right;'>{icon_str_l}</div>"
            f"<div class='m-team left'>{t1_html}</div>"
            f"<div class='m-score'>{g1} - {g2}{extra_str}</div>"
            f"<div class='m-team right'>{t2_html}</div>"
            f"<div class='match-events' style='display:inline-block; width:25px; text-align:left;'>{icon_str_r}</div>"
            f"</div>"
        )

    return (3, 0) if actual_winner == t1 else ((1, 1) if actual_winner == "Draw" else (0, 3)), actual_winner, g1, g2, extra_str, incidents# @title
