import re
import ipywidgets as widgets
from IPython.display import display, clear_output

# Extract countries strictly in the order they appear in RAW_ROSTERS
raw_order_countries = list(RAW_ROSTERS.keys())

team_dropdown_field = widgets.Dropdown(
    options=raw_order_countries,
    value="Canada" if "Canada" in raw_order_countries else raw_order_countries[0],
    description="Country:",
    layout=widgets.Layout(width="45%")
)

text_input_area = widgets.Textarea(
    value="",
    placeholder="Paste the massive block of copied text from the FIFACM website table here...",
    description="FIFACM Data:",
    layout=widgets.Layout(width="98%", height="250px")
)

parse_action_btn = widgets.Button(
    description="Parse Data",
    button_style="success",
    icon="bolt",
    layout=widgets.Layout(width="30%", height="36px")
)

reset_action_btn = widgets.Button(
    description="Reset Text",
    button_style="danger",
    icon="trash",
    layout=widgets.Layout(width="20%", height="36px")
)

code_output_box = widgets.Output(
    layout=widgets.Layout(border="1px solid #cbd5e1", padding="10px", background_color="#f8fafc")
)

# Global tracking variable to maintain current layout state across manual form changes
LAST_PARSED_STATE = {}

def execute_roster_parse_ui(b):
    global LAST_PARSED_STATE
    team_name = team_dropdown_field.value
    raw_text = text_input_area.value

    if not raw_text.strip():
        with code_output_box:
            clear_output()
            print("⚠️ Error: Please paste some text from FIFACM into the input area.")
        return

    team_data = RAW_ROSTERS[team_name]

    # Store initial extraction structures in state variable
    LAST_PARSED_STATE = {
        "team_name": team_name,
        "matched": {"GK": [], "DF": [], "MF": [], "AT": []},
        "missing": []
    }

    def get_raw_name_and_fallback(p_record):
        if isinstance(p_record, tuple):
            return p_record[0], (p_record[2] if len(p_record) >= 3 else 75)
        return str(p_record), 75

    for pos in ["GK", "DF", "MF", "AT"]:
        for p in team_data[pos]:
            name, fallback_rating = get_raw_name_and_fallback(p)

            pattern = re.escape(name) + r'.*?\b(\d{2})\b'
            match = re.search(pattern, raw_text, re.IGNORECASE | re.DOTALL)

            if match:
                new_rating = int(match.group(1))
                LAST_PARSED_STATE["matched"][pos].append((name, new_rating))
            else:
                LAST_PARSED_STATE["missing"].append({"name": name, "pos": pos, "fallback": fallback_rating})

    render_output_view()

def render_output_view():
    with code_output_box:
        clear_output()

        team_name = LAST_PARSED_STATE["team_name"]
        matched = LAST_PARSED_STATE["matched"]
        missing = LAST_PARSED_STATE["missing"]

        total_matched = sum(len(lst) for lst in matched.values())
        total_players = total_matched + len(missing)

        print(f"# Total Squad Players: {total_players} (Matched: {total_matched} | Missing: {len(missing)})\n")

        # 1. Generate the interactive manual input fields for missing players if there are any
        if missing:
            display(widgets.HTML("<div style='color:#b91c1c; font-weight:bold; margin-bottom:5px;'>⚠️ Missing Players Detected (Type custom ratings below):</div>"))

            manual_widgets = []
            for item in missing:
                num_input = widgets.BoundedIntText(value=item["fallback"], min=40, max=99, step=1, layout=widgets.Layout(width="60px"))
                lbl = widgets.HTML(f"<div style='width:220px; font-size:11px;'><b>{item['name']}</b> ({item['pos']})</div>")
                item["widget"] = num_input  # link widget instance back to dictionary entry reference
                manual_widgets.append(widgets.HBox([lbl, num_input], layout=widgets.Layout(margin="2px 0px")))

            apply_ratings_btn = widgets.Button(description="Apply Manual Ratings", button_style="warning", icon="check", layout=widgets.Layout(width="200px", margin="5px 0px"))

            def on_apply_click(b):
                # Transfer values from widgets to data records, then move them to the matched category
                for item in list(LAST_PARSED_STATE["missing"]):
                    rating_value = item["widget"].value
                    LAST_PARSED_STATE["matched"][item["pos"]].append((item["name"], rating_value))
                    LAST_PARSED_STATE["missing"].remove(item)
                render_output_view()

            apply_ratings_btn.on_click(on_apply_click)
            display(widgets.VBox(manual_widgets + [apply_ratings_btn]))
            print("-" * 80 + "\n")

        # 2. Compile and display the clean dictionary code block text
        final_roster = {"GK": [], "DF": [], "MF": [], "AT": []}

        # Add current matched and manually updated entries
        for pos in ["GK", "DF", "MF", "AT"]:
            for name, rating in matched[pos]:
                if rating > 89: tier = "SUPERSTAR"
                elif rating > 83: tier = "STAR"
                elif rating > 79: tier = "STARTER"
                elif rating >= 75: tier = "WISSEL"
                else: tier = "RESERVE"
                final_roster[pos].append((name, tier, rating))

        # Append remaining unhandled missing items using fallback configuration
        for item in missing:
            rating = item["fallback"]
            if rating > 89: tier = "SUPERSTAR"
            elif rating > 83: tier = "STAR"
            elif rating > 79: tier = "STARTER"
            elif rating >= 75: tier = "WISSEL"
            else: tier = "RESERVE"
            final_roster[item["pos"]].append((item["name"], tier, rating))

        print(f'# Copy and paste this directly into RAW_ROSTERS inside Cell 1:\n')
        print(f'    "{team_name}": {{')
        for pos in ["GK", "DF", "MF", "AT"]:
            # Ensure sorting maintains descending skill level distribution format internally
            final_roster[pos].sort(key=lambda x: x[2], reverse=True)
            players_str = ", ".join([f'("{p[0]}", "{p[1]}", {p[2]})' for p in final_roster[pos]])
            print(f'        "{pos}": [{players_str}],')
        print('    },')

def execute_reset_ui(b):
    text_input_area.value = ""
    with code_output_box:
        clear_output()

parse_action_btn.on_click(execute_roster_parse_ui)
reset_action_btn.on_click(execute_reset_ui)

