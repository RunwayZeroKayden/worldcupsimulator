def render_tactical_blackboard(*args):
    team1 = blackboard_country_select.value
    opp_val = blackboard_opp_select.value
    ignore_injuries = (blackboard_squad_toggle.value == 'Best Possible XI')

    is_snap = opp_val.startswith("Played: ")
    snap_data = None

    if is_snap and 'match_snapshots' in globals():
        opp_code = opp_val.split("vs ")[1].split(" (")[0]
        for m_key, snap in match_snapshots.items():
            if (snap["t1_name"] == team1 and FIFA_CODES.get(snap["t2_name"], snap["t2_name"]) == opp_code) or \
               (snap["t2_name"] == team1 and FIFA_CODES.get(snap["t1_name"], snap["t1_name"]) == opp_code):
                snap_data = snap
                break

    with bb_out_left:
        clear_output()
        if team1 != "Select a Team...":
            html_t1 = generate_team_profile_html(team1, is_snap=is_snap, snap_data=snap_data, ignore_injuries=ignore_injuries, is_team1=True)
            display(HTML(html_t1))

    with bb_out_right:
        clear_output()
        if opp_val != "Select Opponent..." and team1 != "Select a Team...":
            opp_team = opp_val
            if is_snap:
                opp_code = opp_val.split("vs ")[1].split(" (")[0]
                for t_name, t_code in FIFA_CODES.items():
                    if t_code == opp_code:
                        opp_team = t_name
                        break

            html_t2 = generate_team_profile_html(opp_team, is_snap=is_snap, snap_data=snap_data, ignore_injuries=ignore_injuries, is_team1=False)
            display(HTML(html_t2))

    with bb_out_mid:
        clear_output()
        if team1 != "Select a Team..." and opp_val != "Select Opponent...":
            opp_team = opp_val
            if is_snap:
                opp_code = opp_val.split("vs ")[1].split(" (")[0]
                for t_name, t_code in FIFA_CODES.items():
                    if t_code == opp_code:
                        opp_team = t_name
                        break

            t1_mpr, t1_off, t1_def = get_team_metrics_obj(team1, ignore_injuries, snap_data)
            t2_mpr, t2_off, t2_def = get_team_metrics_obj(opp_team, ignore_injuries, snap_data)

            mpr_diff = t1_mpr - t2_mpr
            off_vs_def = t1_off - t2_def
            def_vs_off = t1_def - t2_off

            diff_html = f"<div style='margin-top:20px; padding:10px; background:#f8fafc; border:1px solid #cbd5e1; border-radius:6px; font-family:Segoe UI;'>"
            diff_html += f"<h4 style='margin-top:0; text-align:center; color:#0f3460;'>Head-to-Head Deltas</h4>"

            mpr_col = "#16a34a" if mpr_diff > 0 else "#dc2626"
            ovd_col = "#16a34a" if off_vs_def > 0 else "#dc2626"
            dvo_col = "#16a34a" if def_vs_off > 0 else "#dc2626"

            diff_html += f"<div style='display:flex; justify-content:space-between; border-bottom:1px solid #e2e8f0; padding:4px 0;'><span style='font-size:11px;'>MPR Advantage:</span> <b style='color:{mpr_col}; font-size:12px;'>{mpr_diff:+.1f}</b></div>"
            diff_html += f"<div style='display:flex; justify-content:space-between; border-bottom:1px solid #e2e8f0; padding:4px 0;'><span style='font-size:11px;'>{FIFA_CODES.get(team1, team1)} Off vs {FIFA_CODES.get(opp_team, opp_team)} Def:</span> <b style='color:{ovd_col}; font-size:12px;'>{off_vs_def:+}</b></div>"
            diff_html += f"<div style='display:flex; justify-content:space-between; padding:4px 0;'><span style='font-size:11px;'>{FIFA_CODES.get(team1, team1)} Def vs {FIFA_CODES.get(opp_team, opp_team)} Off:</span> <b style='color:{dvo_col}; font-size:12px;'>{def_vs_off:+}</b></div>"
            diff_html += "</div>"

            display(HTML(diff_html))

def update_opp_dropdown_options(*args):
    team = blackboard_country_select.value
    current_opp = blackboard_opp_select.value

    options = ["Select Opponent..."]
    played_options = []

    if team != "Select a Team..." and 'match_snapshots' in globals():
        for m_key, snap in match_snapshots.items():
            if snap["t1_name"] == team or snap["t2_name"] == team:
                opp = snap["t2_name"] if snap["t1_name"] == team else snap["t1_name"]
                opp_code = FIFA_CODES.get(opp, opp)
                played_options.append(f"Played: vs {opp_code} ({snap['score']})")

    if played_options:
        options.extend(played_options)
        options.append("--- Theoretical Matchups ---")

    options.extend([t for t in all_valid_teams if t != team])

    blackboard_opp_select.options = options

    # Restoring selection allows switching squad type without resetting the opponent drop down
    if current_opp in options:
        blackboard_opp_select.value = current_opp
    else:
        blackboard_opp_select.value = "Select Opponent..."

    render_tactical_blackboard()

blackboard_country_select.observe(update_opp_dropdown_options, names="value")
blackboard_squad_toggle.observe(render_tactical_blackboard, names="value")
blackboard_opp_select.observe(render_tactical_blackboard, names="value")

