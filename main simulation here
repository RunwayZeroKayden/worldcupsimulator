def generate_team_profile_html(team, is_snap=False, snap_data=None, ignore_injuries=False, is_team1=True):
    if team == "Select a Team..." or team not in REAL_SQUADS:
        return ""

    base_xi = get_starting_xi(team, ignore_status=True)
    base_def = sum([p[1] for p in base_xi if p[2] in ["GK", "DF"]])
    base_off = sum([p[1] for p in base_xi if p[2] in ["MF", "AT"]])
    base_mpr = (TEAM_METRICS.get(team, {"ELO": 1500})["ELO"] + TEAM_METRICS.get(team, {"PELE": 1500})["PELE"]) / 2

    rc_list, inj_list = [], []
    if is_snap and snap_data:
        xi_players = snap_data["t1_xi"] if snap_data["t1_name"] == team else snap_data["t2_xi"]
        rc_list = snap_data["t1_rc"] if snap_data["t1_name"] == team else snap_data["t2_rc"]
        inj_list = snap_data.get("t1_inj", []) if snap_data["t1_name"] == team else snap_data.get("t2_inj", [])
        status_header = f"<span style='color:#d97706;'>MATCH SNAPSHOT</span>"
    else:
        xi_players = get_starting_xi(team, ignore_status=ignore_injuries)
        if ignore_injuries:
             status_header = "<span style='color:#2563eb;'>THEORETICAL BEST XI</span>"
        else:
             status_header = "<span style='color:#16a34a;'>LIVE SQUAD</span>"

    active_names = [p[0] for p in xi_players]
    missing_players = [p for p in base_xi if p[0] not in active_names]

    gks = [p for p in xi_players if p[2] == "GK"]
    dfs = [p for p in xi_players if p[2] == "DF"]
    mfs = [p for p in xi_players if p[2] == "MF"]
    ats = [p for p in xi_players if p[2] == "AT"]

    formation_string = f"{len(dfs)}-{len(mfs)}-{len(ats)}"

    html_pitch = "<div class='pitch-canvas' style='width:100%; max-width:320px; height:360px; margin:10px auto 0 auto;'>"
    html_pitch += "<div class='pitch-center-line'></div><div class='pitch-center-circle'></div>"
    html_pitch += "<div class='pitch-penalty-box-top'></div><div class='pitch-penalty-box-bot'></div>"

    def add_player_html(name, rating, left_pct, top_px):
        # Draws live incident badges directly onto the pitch snapshot
        rc_overlay = ""
        if name in rc_list: rc_overlay = "<div style='position:absolute; top:-10px; right:-5px; font-size:14px; z-index:20;'>🟥</div>"
        elif name in inj_list: rc_overlay = "<div style='position:absolute; top:-10px; right:-5px; font-size:14px; z-index:20;'>🚑</div>"
        return f"<div class='player-node-icon' style='left:{left_pct}%; top:{top_px}px; transform:translateX(-50%) scale(0.9);'>{rc_overlay}<div class='player-badge-oval'>{name.split()[-1]}</div><div class='player-rating-circle'>{rating}</div></div>"

    if gks: html_pitch += add_player_html(gks[0][0], gks[0][1], 50, 310)
    for idx, p in enumerate(dfs): html_pitch += add_player_html(p[0], p[1], (100 / (len(dfs) + 1)) * (idx + 1), 240)
    for idx, p in enumerate(mfs): html_pitch += add_player_html(p[0], p[1], (100 / (len(mfs) + 1)) * (idx + 1), 150)
    for idx, p in enumerate(ats): html_pitch += add_player_html(p[0], p[1], (100 / (len(ats) + 1)) * (idx + 1), 50)
    html_pitch += "</div>"

    curr_def = sum([p[1] for p in gks + dfs])
    curr_off = sum([p[1] for p in mfs + ats])
    def_diff = curr_def - base_def
    off_diff = curr_off - base_off

    def format_delta(val):
        if val > 0: return f"<span style='color:#16a34a; font-size:10px;'> (+{val})</span>"
        elif val < 0: return f"<span style='color:#dc2626; font-size:10px;'> ({val})</span>"
        return ""

    stats_html = f"<div style='font-family:Segoe UI; width:100%; max-width:340px; margin: 0 auto;'><h3 style='margin-top:0; color:#0f3460; font-size:18px; text-align:center;'>{get_flag(team)} {team}</h3>"
    stats_html += f"<div style='font-size:11px; font-weight:bold; background:#f1f5f9; padding:4px; margin-bottom:8px; border-radius:4px; text-align:center;'>{status_header}</div>"

    stats_html += f"<table style='width:100%; font-size:12px; border-collapse:collapse; margin-bottom:10px;'>"
    stats_html += f"<tr style='border-bottom:1px solid #cbd5e1;'><td style='padding:4px; font-weight:bold;'>Formation:</td><td style='padding:4px; color:#e94560; font-weight:bold; text-align:right;'>{formation_string}</td></tr>"
    stats_html += f"<tr style='border-bottom:1px solid #cbd5e1;'><td style='padding:4px; font-weight:bold;'>Base MPR:</td><td style='padding:4px; font-weight:bold; text-align:right;'>{base_mpr:.1f}</td></tr>"
    stats_html += f"<tr style='border-bottom:1px solid #cbd5e1; background:#fef2f2;'><td style='padding:4px; font-weight:bold; color:#991b1b;'>Offence:</td><td style='padding:4px; font-weight:bold; color:#991b1b; text-align:right;'>{curr_off}{format_delta(off_diff)}</td></tr>"
    stats_html += f"<tr style='border-bottom:1px solid #cbd5e1; background:#f0fdf4;'><td style='padding:4px; font-weight:bold; color:#166534;'>Defence:</td><td style='padding:4px; font-weight:bold; color:#166534; text-align:right;'>{curr_def}{format_delta(def_diff)}</td></tr>"
    stats_html += "</table>"

    out_html = "<div style='background:#fff1f2; border:1px solid #fecdd3; border-radius:4px; padding:6px; margin-bottom:10px;'>"
    out_html += "<b style='font-size:11px; color:#be123c;'>Unavailable / Replaced:</b><br>"
    if missing_players:
        for mp in missing_players:
            p_name = mp[0]
            reason_icon = "🔄"
            if p_name in player_status_injured and player_status_injured[p_name].get("matches", 0) > 0:
                reason_icon = "🚑"
            elif p_name in team_suspensions and team_suspensions[p_name].get("matches", 0) > 0:
                reason_icon = "⛔"
            out_html += f"<div style='font-size:10px; color:#881337; margin-top:2px;'>{reason_icon} {p_name} ({mp[1]} {mp[2]})</div>"
    else:
        out_html += "<div style='font-size:10px; color:#9f1239; margin-top:2px;'>✔️ Full squad fit</div>"
    out_html += "</div>"

    def render_line(pos, p_list):
        if not p_list: return ""
        badges = "".join([f"<span style='background:#e2e8f0; color:#1e293b; padding:2px 6px; border-radius:4px; margin:2px; font-size:10px; display:inline-block;'>{p[0]} <b>{p[1]}</b></span>" for p in p_list])
        return f"<div style='display:flex; flex-wrap:wrap; align-items:center; margin-bottom:6px;'><b style='width:35px; font-size:11px; color:#0f3460;'>[{pos}]</b> {badges}</div>"

    lineup_html = f"<div style='max-height:120px; overflow-y:auto; border:1px solid #cbd5e1; border-radius:4px; padding:5px; background:#f8fafc;'>"
    lineup_html += render_line("GK", gks) + render_line("DF", dfs) + render_line("MF", mfs) + render_line("AT", ats) + "</div>"

    return stats_html + out_html + lineup_html + html_pitch + "</div>"

def get_team_metrics_obj(team, ignore_injuries=False, snap_data=None):
    if snap_data:
        xi = snap_data["t1_xi"] if snap_data["t1_name"] == team else snap_data["t2_xi"]
    else:
        xi = get_starting_xi(team, ignore_status=ignore_injuries)

    base_mpr = (TEAM_METRICS.get(team, {"ELO": 1500})["ELO"] + TEAM_METRICS.get(team, {"PELE": 1500})["PELE"]) / 2
    curr_def = sum([p[1] for p in xi if p[2] in ["GK", "DF"]])
    curr_off = sum([p[1] for p in xi if p[2] in ["MF", "AT"]])
    return base_mpr, curr_off, curr_def

def get_safe_match_key(g_id, t1, t2):
    return tuple(sorted([t1, t2]))

def safe_parse_int(widget_instance):
    try:
        val = widget_instance.value.strip()
        if not val: return None
        digits = "".join([c for c in val if c.isdigit()])
        return int(digits) if digits else None
    except:
        return None

def create_score_observer(g_id, m_key, w1, w2):
    def observer(change):
        global INTERNAL_MUTATION_FLAG
        if INTERNAL_MUTATION_FLAG: return
        g1, g2 = safe_parse_int(w1), safe_parse_int(w2)
        if g1 is not None or g2 is not None:
            MANUAL_SCORES[(g_id, m_key)] = (g1 or 0, g2 or 0)
            w1.add_class("manual-input-style"); w2.add_class("manual-input-style")
            w1.remove_class("simulated-input-style"); w2.remove_class("simulated-input-style")
        else:
            MANUAL_SCORES.pop((g_id, m_key), None)
            w1.remove_class("manual-input-style"); w2.remove_class("manual-input-style")
        if POST_SIM_REACTIVE_LOCK:
            run_master_calculation_pipeline(is_reactive_pass=True)
    return observer

def create_bracket_observer(tier_name, idx, w1, w2):
    def observer(change):
