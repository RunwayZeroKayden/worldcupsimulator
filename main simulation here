    status_board_widget.value = ""
    run_master_calculation_pipeline(is_reactive_pass=False)

    # NEW: Force the blackboard to reset its dropdowns
    blackboard_country_select.value = "Select a Team..."
    update_opp_dropdown_options()

def run_constrained_monte_carlo_pipeline(b):
    global LIVE_RESULTS
    with mc_output_area:
        clear_output()
        sims = sim_count_dropdown.value
        display(HTML(f"<div style='font-family:Segoe UI; padding:8px; background:#e8f4fd; color:#0f3460; font-weight:bold;'>⚙️ Running {sims:,} deep tactical simulation loops... Please wait.</div>"))

        results = {t: {
            "1st": 0, "2nd": 0, "3rd": 0, "4th": 0, "QF": 0, "R16": 0, "R32": 0, "Group": 0,
            "gp1": 0, "gp2": 0, "gp3_q": 0, "gp3_e": 0, "gp4": 0
        } for t in TEAM_METRICS.keys()}

        cols_tracker = ["Round of 32", "Round of 16", "Quarter-Finals"]
        elim_stages = {t: {r: 0 for r in cols_tracker} for t in TEAM_METRICS.keys()}
        executioners = {t: {r: {} for r in ["Round of 32", "Round of 16", "Quarter-Finals", "Semi-Finals", "Final"]} for t in TEAM_METRICS.keys()}
        overall_executioners = {t: {} for t in TEAM_METRICS.keys()}

        for _ in range(sims):
            reset_tournament_state()
            plac, thirds_pool, grp_standings = {}, [], {}

            for g_id, teams in GROUPS.items():
                table_map = {t: {"pts": 0, "gd": 0, "gf": 0, "name": t, "group": g_id} for t in teams}
                matchups = [(teams[0], teams[1]), (teams[2], teams[3]), (teams[0], teams[2]), (teams[3], teams[1]), (teams[1], teams[2]), (teams[3], teams[0])] if len(teams) == 4 else [(teams[i], teams[j]) for i in range(len(teams)) for j in range(i + 1, len(teams))]
                for t1, t2 in matchups:
                    m_key = get_safe_match_key(g_id, t1, t2)
                    if (g_id, m_key) in MANUAL_SCORES:
                        g1, g2 = MANUAL_SCORES[(g_id, m_key)]
                        sim_winner = t1 if g1 > g2 else (t2 if g2 > g1 else "Draw")
                    else:
                        _, sim_winner, g1, g2, _, _ = simulate_match(t1, t2, can_draw=True)

                    table_map[t1]["gf"] += g1; table_map[t1]["gd"] += (g1 - g2)
                    table_map[t2]["gf"] += g2; table_map[t2]["gd"] += (g2 - g1)
                    if sim_winner == t1: table_map[t1]["pts"] += 3
                    elif sim_winner == t2: table_map[t2]["pts"] += 3
                    else: table_map[t1]["pts"] += 1; table_map[t2]["pts"] += 1

                sim_rows = sorted(table_map.values(), key=lambda x: (x["pts"], x["gd"], x["gf"]), reverse=True)
                grp_standings[g_id] = sim_rows
                plac[f"1{g_id}"] = sim_rows[0]["name"]; plac[f"2{g_id}"] = sim_rows[1]["name"]; thirds_pool.append(sim_rows[2])

            sorted_thirds = sorted(thirds_pool, key=lambda x: (x["pts"], x["gd"], x["gf"]), reverse=True)

            forced_adv = [t["name"] for t in sorted_thirds if WILDCARD_OVERRIDES.get(t["name"]) == "Advance"]
            forced_elim = [t["name"] for t in sorted_thirds if WILDCARD_OVERRIDES.get(t["name"]) == "Eliminate"]
            auto_adv = [t["name"] for t in sorted_thirds if t["name"] not in forced_adv and t["name"] not in forced_elim]
            adv_list = (forced_adv + auto_adv)[:8]
            adv_names = set(adv_list)

            for idx, slot in enumerate(slots_order):
                plac[slot] = adv_list[idx] if idx < len(adv_list) else "TBD"

            for g_id, srows in grp_standings.items():
                for rank_idx, row in enumerate(srows):
                    tn = row["name"]
                    if rank_idx == 0: results[tn]["gp1"] += 1
                    elif rank_idx == 1: results[tn]["gp2"] += 1
                    elif rank_idx == 2:
                        if tn in adv_names: results[tn]["gp3_q"] += 1
                        else: results[tn]["gp3_e"] += 1
                    elif rank_idx == 3: results[tn]["gp4"] += 1

            knockout_participants = set(plac.values())
            for t in TEAM_METRICS.keys():
                if t not in knockout_participants: results[t]["Group"] += 1

            # Round of 32
            current_tier = [(plac.get(p1), plac.get(p2)) for p1, p2 in BRACKET_MATRIX]
            r16_inputs = []
            for idx, (t1, t2) in enumerate(current_tier):
                if t1 and t2:
                    if ("Round of 32", idx) in MANUAL_BRACKET:
                        s1, s2 = MANUAL_BRACKET[("Round of 32", idx)]
                        if s1 > s2: w = t1
                        elif s2 > s1: w = t2
                        else: w = t1 if random.random() < 0.5 else t2
                    else:
                        _, w, g1, g2, _, _ = simulate_match(t1, t2, can_draw=False)

                    loser = t2 if w == t1 else t1
                    executioners[loser]["Round of 32"][w] = executioners[loser]["Round of 32"].get(w, 0) + 1
                    overall_executioners[loser][w] = overall_executioners[loser].get(w, 0) + 1
                    elim_stages[loser]["Round of 32"] += 1
                    r16_inputs.append(w)
                else: r16_inputs.append(t1 if t1 else t2)

            # Round of 16
            current_tier = [(r16_inputs[i], r16_inputs[i+1]) for i in range(0, len(r16_inputs), 2)]
            qf_inputs = []
            for idx, (t1, t2) in enumerate(current_tier):
                if t1 and t2:
                    if ("Round of 16", idx) in MANUAL_BRACKET:
                        s1, s2 = MANUAL_BRACKET[("Round of 16", idx)]
                        if s1 > s2: w = t1
                        elif s2 > s1: w = t2
                        else: w = t1 if random.random() < 0.5 else t2
                    else:
                        _, w, g1, g2, _, _ = simulate_match(t1, t2, can_draw=False)
                    loser = t2 if w == t1 else t1
                    executioners[loser]["Round of 16"][w] = executioners[loser]["Round of 16"].get(w, 0) + 1
                    overall_executioners[loser][w] = overall_executioners[loser].get(w, 0) + 1
                    elim_stages[loser]["Round of 16"] += 1
                    qf_inputs.append(w)
                else: qf_inputs.append(t1 if t1 else t2)

            # Quarter-Finals
            current_tier = [(qf_inputs[i], qf_inputs[i+1]) for i in range(0, len(qf_inputs), 2)]
            sf_inputs = []
            for idx, (t1, t2) in enumerate(current_tier):
                if t1 and t2:
                    if ("Quarter-Finals", idx) in MANUAL_BRACKET:
                        s1, s2 = MANUAL_BRACKET[("Quarter-Finals", idx)]
                        if s1 > s2: w = t1
                        elif s2 > s1: w = t2
                        else: w = t1 if random.random() < 0.5 else t2
                    else:
                        _, w, g1, g2, _, _ = simulate_match(t1, t2, can_draw=False)
                    loser = t2 if w == t1 else t1
                    executioners[loser]["Quarter-Finals"][w] = executioners[loser]["Quarter-Finals"].get(w, 0) + 1
                    overall_executioners[loser][w] = overall_executioners[loser].get(w, 0) + 1
                    elim_stages[loser]["Quarter-Finals"] += 1
                    sf_inputs.append(w)
                else: sf_inputs.append(t1 if t1 else t2)

            # Semi-Finals & Bracket Conclusions
            current_tier = [(sf_inputs[i], sf_inputs[i+1]) for i in range(0, len(sf_inputs), 2)]
            final_inputs, sf_losers = [], []
            for idx, (t1, t2) in enumerate(current_tier):
                if t1 and t2:
                    if ("Semi-Finals", idx) in MANUAL_BRACKET:
                        s1, s2 = MANUAL_BRACKET[("Semi-Finals", idx)]
                        if s1 > s2: w = t1
                        elif s2 > s1: w = t2
                        else: w = t1 if random.random() < 0.5 else t2
                    else:
                        _, w, g1, g2, _, _ = simulate_match(t1, t2, can_draw=False)
                    loser = t2 if w == t1 else t1
                    executioners[loser]["Semi-Finals"][w] = executioners[loser]["Semi-Finals"].get(w, 0) + 1
                    overall_executioners[loser][w] = overall_executioners[loser].get(w, 0) + 1
                    sf_losers.append(loser)
                    final_inputs.append(w)
                else:
                    final_inputs.append(t1 if t1 else t2)
                    sf_losers.append(t2 if t1 else t1)

            if len(final_inputs) == 2:
                t1, t2 = final_inputs[0], final_inputs[1]
                if ("Final", 0) in MANUAL_BRACKET:
                    s1, s2 = MANUAL_BRACKET[("Final", 0)]
                    if s1 > s2: champ = t1
                    elif s2 > s1: champ = t2
                    else: champ = t1 if random.random() < 0.5 else t2
                else:
                    _, champ, g1, g2, _, _ = simulate_match(t1, t2, can_draw=False)
                runner_up = t2 if champ == t1 else t1
                results[champ]["1st"] += 1
                results[runner_up]["2nd"] += 1
                executioners[runner_up]["Final"][champ] = executioners[runner_up]["Final"].get(champ, 0) + 1
                overall_executioners[runner_up][champ] = overall_executioners[runner_up].get(champ, 0) + 1

            if len(sf_losers) == 2:
                tl1, tl2 = sf_losers[0], sf_losers[1]
                if ("Third-Place Play-Off", 0) in MANUAL_BRACKET:
                    s1, s2 = MANUAL_BRACKET[("Third-Place Play-Off", 0)]
                    if s1 > s2: t3_winner = tl1
                    elif s2 > s1: t3_winner = tl2
                    else: t3_winner = tl1 if random.random() < 0.5 else tl2
                else:
                    _, t3_winner, _, _, _, _ = simulate_match(tl1, tl2, can_draw=False)
                t4_loser = tl2 if t3_winner == tl1 else tl1
                results[t3_winner]["3rd"] += 1
                results[t4_loser]["4th"] += 1

        for t in TEAM_METRICS.keys():
            results[t]["R32"] = elim_stages[t]["Round of 32"]
            results[t]["R16"] = elim_stages[t]["Round of 16"]
            results[t]["QF"] = elim_stages[t]["Quarter-Finals"]

        # --- GENERATE MATRICES ---
        df1 = pd.DataFrame.from_dict(results, orient="index")
        df1["→ Final"] = df1["1st"] + df1["2nd"]
        df1["→ SF"] = df1["→ Final"] + df1["3rd"] + df1["4th"]
        df1["→ QF"] = df1["→ SF"] + df1["QF"]
        df1["→ R16"] = df1["→ QF"] + df1["R16"]
        df1["→ R32"] = df1["→ R16"] + df1["R32"]

        display_df1 = df1[["1st", "2nd", "3rd", "4th", "→ Final", "→ SF", "→ QF", "→ R16", "→ R32", "Group"]].copy()
        display_df1.columns = ["🥇 Trophy Winner", "🥈 2nd Place", "🥉 3rd Place", "4th Place", "→ Reach Final", "→ Reach Semis", "→ Reach Quarters", "→ Reach R16", "→ Reach R32", "Group Exit"]
        display_df1 = display_df1.sort_values(by="🥇 Trophy Winner", ascending=False)
        for col in display_df1.columns: display_df1[col] = (display_df1[col] / sims * 100)
        display_df1.index = [f"{get_flag(t)} {FIFA_CODES.get(t, t)}" for t in display_df1.index]
        styled_df1 = display_df1.style.background_gradient(cmap='Blues', axis=0).format("{:.1f}%")

        display_df2 = df1[["gp1", "gp2", "gp3_q", "gp3_e", "gp4"]].copy()
        display_df2.columns = ["🥇 Group 1st", "🥈 Group 2nd", "3rd (Qualified)", "3rd (Eliminated)", "💀 Group 4th"]
        display_df2 = display_df2.sort_values(by="🥇 Group 1st", ascending=False)
        for col in display_df2.columns: display_df2[col] = (display_df2[col] / sims * 100)
        display_df2.index = [f"{get_flag(t)} {FIFA_CODES.get(t, t)}" for t in display_df2.index]
        styled_df2 = display_df2.style.background_gradient(cmap='Greens', axis=0).format("{:.1f}%")

        elim_records = []
        for t in TEAM_METRICS.keys():
            row_data = {"Team": t}

            # Formats the top 3 overall executioners with their raw global slice tracking counts
            if overall_executioners[t]:
                total_losses = sum(overall_executioners[t].values())
                sorted_overall = sorted(overall_executioners[t].items(), key=lambda x: x[1], reverse=True)[:3]
                strings_overall = []
                for opp, count in sorted_overall:
                    overall_pct = (count / total_losses * 100) if total_losses else 0
                    strings_overall.append(f"{get_flag(opp)} <b>{FIFA_CODES.get(opp, opp)}</b> ({overall_pct:.1f}%)")
                row_data["Primary Executioner (Total)"] = "<br>".join(strings_overall)
            else:
                row_data["Primary Executioner (Total)"] = "-"

            # Evaluates all 5 milestones to discover the absolute highest elimination risk column
            round_totals = {
                "Round of 32": elim_stages[t]["Round of 32"],
                "Round of 16": elim_stages[t]["Round of 16"],
                "Quarter-Finals": elim_stages[t]["Quarter-Finals"],
                "Semi-Finals": results[t]["3rd"] + results[t]["4th"],
                "Final": results[t]["2nd"]
            }
            most_likely_round = max(round_totals, key=round_totals.get) if sum(round_totals.values()) > 0 else "Round of 32"

            # Scans the entire grid row layout to establish the absolute peak cell opponent count
            max_cell_count = -1
            absolute_killer_round = None
            absolute_killer_opp = None
            for r_name in ["Round of 32", "Round of 16", "Quarter-Finals", "Semi-Finals", "Final"]:
                for opp, count in executioners[t][r_name].items():
                    if count > max_cell_count:
                        max_cell_count = count
                        absolute_killer_round = r_name
                        absolute_killer_opp = opp

            for r_name in ["Round of 32", "Round of 16", "Quarter-Finals", "Semi-Finals", "Final"]:
                round_data = executioners[t][r_name]
                total_round_elims = round_totals[r_name]

                cell_html = f"<b style='font-size:11px; color:#1e293b;'>Elimination: {(total_round_elims / sims * 100):.1f}%</b><br>"
                sorted_execs = sorted(round_data.items(), key=lambda x: x[1], reverse=True)[:5]
                strings = []
                for idx, (opp, count) in enumerate(sorted_execs):
                    pct = (count / total_round_elims * 100) if total_round_elims else 0
                    team_str = f"{get_flag(opp)}{FIFA_CODES.get(opp, opp)} ({pct:.1f}%)"

                    # Highlights the cell containing the true global maximum count across the entire simulation
                    if r_name == absolute_killer_round and opp == absolute_killer_opp and max_cell_count > 0:
                        strings.append(f"<span style='background-color:#fca5a5; font-weight:bold; padding:1px 4px; border-radius:3px; display:inline-block; margin:1px 0;'>{team_str} 🎯</span>")
                    elif idx == 0 and total_round_elims > 0:
                        strings.append(f"<span style='background-color:#fef08a; padding:1px 4px; border-radius:3px; display:inline-block; margin:1px 0;'>{team_str}</span>")
                    else:
                        strings.append(f"<span>{team_str}</span>")

                cell_html += "<div>" + "<br>".join(strings) + "</div>" if strings else "<span style='color:#ccc;'>-</span>"

                # Encircles the specific tournament round representing the largest absolute fallout risk stage
                if r_name == most_likely_round and total_round_elims > 0:
                    cell_html = f"<div style='background-color:#fff5f5; border:1px dashed #fca5a5; padding:5px; border-radius:4px;'>{cell_html}</div>"

                row_data[r_name] = cell_html
            elim_records.append(row_data)

        df3 = pd.DataFrame(elim_records).set_index("Team").reindex(TEAM_METRICS.keys())
        df3.index = [f"{get_flag(t)} {FIFA_CODES.get(t, t)}" for t in df3.index]
        df3 = df3[["Primary Executioner (Total)", "Round of 32", "Round of 16", "Quarter-Finals", "Semi-Finals", "Final"]]
        df3.columns = ["Primary Killer (Total)", "R32 Exit Distribution", "R16 Exit Distribution", "QF Exit Distribution", "SF Exit Distribution", "Final Loss"]

        display(HTML("<h3 style='font-family:Segoe UI; color:#0f3460;'>📈 Knockout Progression Cumulative Heatmap</h3>"))
        display(HTML(styled_df1.to_html()))
        display(HTML("<h3 style='font-family:Segoe UI; color:#166534; margin-top:20px;'>📊 Group Stage Finishing Positions Heatmap</h3>"))
        display(HTML(styled_df2.to_html()))
        display(HTML("<h3 style='font-family:Segoe UI; color:#b91c1c; margin-top:20px;'>⚔️ Per-Round Head-to-Head Executioners Matrix Map</h3>"))
        display(HTML(df3.to_html(escape=False)))

