def satisfy_placement(g_id, cfg):
    targets = {dd.value: idx for idx, dd in enumerate(cfg["order_fields"]) if dd.value}
    if not targets: return
    teams = GROUPS[g_id]

    for _ in range(1500):
        temp_scores = {}
        table_map = {t: {"pts": 0, "gd": 0, "gf": 0, "name": t, "group": g_id} for t in teams}
        matchups = [(teams[0], teams[1]), (teams[2], teams[3]), (teams[0], teams[2]), (teams[3], teams[1]), (teams[1], teams[2]), (teams[3], teams[0])] if len(teams) == 4 else [(teams[i], teams[j]) for i in range(len(teams)) for j in range(i + 1, len(teams))]
        for t1, t2 in matchups:
            m_key = get_safe_match_key(g_id, t1, t2)
            if (g_id, m_key) in MANUAL_SCORES:
                g1, g2 = MANUAL_SCORES[(g_id, m_key)]
            else:
                g1, g2 = random.randint(0, 4), random.randint(0, 4)
            temp_scores[m_key] = (g1, g2)
            table_map[t1]["gf"] += g1; table_map[t1]["gd"] += (g1 - g2)
            table_map[t2]["gf"] += g2; table_map[t2]["gd"] += (g2 - g1)
            if g1 > g2: table_map[t1]["pts"] += 3
            elif g2 > g1: table_map[t2]["pts"] += 3
            else: table_map[t1]["pts"] += 1; table_map[t2]["pts"] += 1

        sim_rows = sorted(table_map.values(), key=lambda x: (x["pts"], x["gd"], x["gf"]), reverse=True)
        valid = True
        for t, target_idx in targets.items():
            if sim_rows[target_idx]["name"] != t:
                valid = False
                break

        if valid:
            global INTERNAL_MUTATION_FLAG
            INTERNAL_MUTATION_FLAG = True
            for m_key, (g1, g2) in temp_scores.items():
                w1, w2 = cfg["score_fields"][m_key]
                w1.value = str(g1)
                w2.value = str(g2)
                MANUAL_SCORES[(g_id, m_key)] = (g1, g2)
                w1.add_class("manual-input-style")
                w2.add_class("manual-input-style")
                w1.remove_class("simulated-input-style")
                w2.remove_class("simulated-input-style")
            INTERNAL_MUTATION_FLAG = False
            return

