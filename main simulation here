def bind_wildcard_override(team_name, dd_widget):
    def observer(change):
        if change["new"] == "Advance":
            WILDCARD_OVERRIDES[team_name] = "Advance"
        elif change["new"] == "Eliminate":
            WILDCARD_OVERRIDES[team_name] = "Eliminate"
        else:
            WILDCARD_OVERRIDES.pop(team_name, None)
        if POST_SIM_REACTIVE_LOCK:
            run_master_calculation_pipeline(is_reactive_pass=True)
    dd_widget.observe(observer, names="value")

def toggle_local_group_mode(g_id, selected_mode):
    global INTERNAL_MUTATION_FLAG
    INTERNAL_MUTATION_FLAG = True
    GROUP_MODES[g_id] = selected_mode
    cfg = group_cards_registry[g_id]
    cfg["score_container"].layout.display = "flex" if selected_mode == "scores" else "none"
    cfg["placement_container"].layout.display = "none" if selected_mode == "scores" else "flex"
    INTERNAL_MUTATION_FLAG = False

def execute_local_group_reset(g_id):
    global INTERNAL_MUTATION_FLAG
    INTERNAL_MUTATION_FLAG = True
    cfg = group_cards_registry[g_id]
    GROUP_MODES[g_id] = "scores"
    for w1, w2 in cfg["score_fields"].values():
        w1.value = ""; w1.remove_class("manual-input-style"); w1.remove_class("simulated-input-style")
        w2.value = ""; w2.remove_class("manual-input-style"); w2.remove_class("simulated-input-style")
    for dd in cfg["order_fields"]: dd.value = None
    for k in list(MANUAL_SCORES.keys()):
        if k[0] == g_id: MANUAL_SCORES.pop(k, None)
    for lbl in cfg["match_events_labels_l"].values(): lbl.value = ""
    for lbl in cfg["match_events_labels_r"].values(): lbl.value = ""
    cfg["score_container"].layout.display = "flex"; cfg["placement_container"].layout.display = "none"
    INTERNAL_MUTATION_FLAG = False
    run_master_calculation_pipeline(is_reactive_pass=False)

