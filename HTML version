            } else { // 5-4-1 Defensiveness Layout Blueprint Matrix
                coords = [
                    { pos: "GK", left: 50, top: 92 },
                    { pos: "DF", left: 12, top: 74 }, { pos: "DF", left: 32, top: 76 }, { pos: "DF", left: 50, top: 78 }, { pos: "DF", left: 68, top: 76 }, { pos: "DF", left: 88, top: 74 },
                    { pos: "MF", left: 15, top: 52 }, { pos: "MF", left: 38, top: 54 }, { pos: "MF", left: 62, top: 54 }, { pos: "MF", left: 85, top: 52 },
