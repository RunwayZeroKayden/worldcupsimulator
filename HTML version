                    m.played = true;
                    m.winner = m.g1 > m.g2 ? m.t1 : (m.g2 > m.g1 ? m.t2 : null);
                    m.suffix = manualScoreOverrides[mKey].suffix || "";
                } else if(forceRandomizeGroupStageSimulations) {
                    let result = calculatePoissonExpectancyGoalsProbabilities(m.t1, m.t2, false);
                    m.g1 = result.g1;
                    m.g2 = result.g2;
                    m.played = true;
                    m.winner = result.winner;
                    m.suffix = "";
                } else {
                    // Retain existing unsimulated configurations state patterns blanks variables values boundaries
                    if(!m.played) {
                        m.g1 = null;
                        m.g2 = null;
                        m.winner = null;
                        m.suffix = "";
                    }
                }

                if(m.played) {
                    totalGoalsAggregatedTracker += (m.g1 + m.g2);
                    totalCalculatedMatchesCounter++;
                }
            });

            // Step 2: Compute standings arrays groups tracking sorting parameters
            recomputeGroupStandingsMatricesTables();

            // Step 3: Extract top qualifiers sequences records buffers vectors configurations mapping paths
            let roundOf32QualifiedTeamsOrderedList = extractRoundOf32QualifiedMatrixSequence();

            // Step 4: Resolve single elimination tracking phases
            resolveKnockoutStagesEvaluationTree(roundOf32QualifiedTeamsOrderedList, forceRandomizeGroupStageSimulations);

            // Tally overall knockout metrics indicators summaries charts numbers
            const stagesKeysList = ["R32", "R16", "QF", "SF", "GF"];
            stagesKeysList.forEach(stk => {
                if(knockoutBracketNodes[stk]) {
                    knockoutBracketNodes[stk].forEach(match => {
                        if(match && match.played) {
                            totalGoalsAggregatedTracker += (match.g1 + match.g2);
                            totalCalculatedMatchesCounter++;
                        }
                    });
                }
            });

            // Refresh UI Views Modules Elements Components Layout Graphics Trees Standings Blocks Row View Grid
            updateWidgetDisplaysMetricsNumbersCounters(totalCalculatedMatchesCounter, totalGoalsAggregatedTracker);
            renderGroupStandingsBlocksGridHTMLDOMContent();
            syncInteractiveFixturesFormsInputFieldsValues();
