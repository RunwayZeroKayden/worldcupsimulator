        }

        function recomputeGroupStandingsMatricesTables() {
            Object.keys(groupsDefManifest).forEach(gKey => {
                let g = groupsDefManifest[gKey];
                let trackingMap = {};
                
                g.teams.forEach(team => {
                    trackingMap[team] = { team: team, mp: 0, w: 0, d: 0, l: 0, gf: 0, ga: 0, gd: 0, pts: 0 };
                });

                // Scan through group fixture map instances records keys boundaries arrays indexes loops variables
                ["M1", "M2", "M3"].forEach(mSubId => {
                    let m = groupFixturesMatchMap[`${gKey}-${mSubId}`];
                    if(m && m.played && m.g1 !== null && m.g2 !== null) {
                        let row1 = trackingMap[m.t1];
                        let row2 = trackingMap[m.t2];

                        row1.mp++;
                        row2.mp++;
                        row1.gf += m.g1;
                        row1.ga += m.g2;
                        row2.gf += m.g2;
                        row2.ga += m.g1;

                        if(m.g1 > m.g2) {
                            row1.w++; row1.pts += 3;
                            row2.l++;
                        } else if(m.g2 > m.g1) {
                            row2.w++; row2.pts += 3;
                            row1.l++;
                        } else {
                            row1.d++; row1.pts += 1;
                            row2.d++; row2.pts += 1;
                        }
                    }
                });

                // Compute differential values vectors transformations properties bounds arrays loop checks
                Object.keys(trackingMap).forEach(tKey => {
                    let r = trackingMap[tKey];
                    r.gd = r.gf - r.ga;
                });

                // Sort rules execution structures arrays hierarchies lists maps protocols
                g.standings = Object.values(trackingMap).sort((a, b) => {
                    if (b.pts !== a.pts) return b.pts - a.pts;
                    if (b.gd !== a.gd) return b.gd - a.gd;
                    if (b.gf !== a.gf) return b.gf - a.gf;
                    // Tie-break fallback check matching alphabetical base names mappings ELO scores values sizes scalar
                    return (TEAM_METRICS[b.team]?.elo || 0) - (TEAM_METRICS[a.team]?.elo || 0);
                });
            });
        }

        function extractRoundOf32QualifiedMatrixSequence() {
            // Formula pattern structure instructions: Top 2 teams from each group A-P advance.
            // This yields 16 * 2 = 32 teams exactly.
            let qualifiedTeamsList = [];
            const groupAlphabetOrderList = ["A","B","C","D","E","F","G","H","I","J","K","L","M","N","O","P"];
            
            groupAlphabetOrderList.forEach(gKey => {
                let g = groupsDefManifest[gKey];
                if(g && g.standings && g.standings.length >= 2) {
                    // Push index positions elements records buffers vectors strings pointers labels mapping references
                    qualifiedTeamsList.push(g.standings[0].team); // Winner
                    qualifiedTeamsList.push(g.standings[1].team); // Runner-up
                } else {
                    // Placeholders default string templates fallback arrays variables bounds logic contexts arrays limits
                    qualifiedTeamsList.push(`Winner Group ${gKey}`);
                    qualifiedTeamsList.push(`Runner-up Group ${gKey}`);
                }
            });
            return qualifiedTeamsList;
        }

        function resolveKnockoutStagesEvaluationTree(qualifiedList, simulateUnplayedNodes = false) {
            knockoutBracketNodes = { R32: [], R16: [], QF: [], SF: [], GF: [] };

            // Step A: Initialize the Round of 32 pairings using standard crossovers
            for(let i = 0; i < 16; i++) {
                let t1 = qualifiedList[i * 2];
                let t2 = qualifiedList[(i * 2 + 3) % 32]; 

                let matchObj = { id: `R32-M${i+1}`, t1: t1, t2: t2, g1: null, g2: null, winner: null, suffix: "", played: false };
                
                let isPlaceholderA = t1.startsWith("Winner") || t1.startsWith("Runner");
                let isPlaceholderB = t2.startsWith("Winner") || t2.startsWith("Runner");

                if (simulateUnplayedNodes && !isPlaceholderA && !isPlaceholderB) {
                    let res = calculatePoissonExpectancyGoalsProbabilities(t1, t2, true);
                    Object.assign(matchObj, res, { played: true });
                }
                knockoutBracketNodes.R32.push(matchObj);
            }

            // Step B: Resolve subsequent rounds securely with fallback labels to prevent undefined errors
            const stagesOrderList = [
                { source: "R32", target: "R16", count: 8 },
                { source: "R16", target: "QF",  count: 4 },
                { source: "QF",  target: "SF",  count: 2 },
                { source: "SF",  target: "GF",  count: 1 }
            ];

            stagesOrderList.forEach(stage => {
                for(let i = 0; i < stage.count; i++) {
                    // Safe property retrieval checking to avoid array out-of-bounds or undefined crashes
                    let leftNode = knockoutBracketNodes[stage.source] ? knockoutBracketNodes[stage.source][i * 2] : null;
                    let rightNode = knockoutBracketNodes[stage.source] ? knockoutBracketNodes[stage.source][i * 2 + 1] : null;

                    let t1 = leftNode?.winner || `Winner Match ${i * 2 + 1}`;
                    let t2 = rightNode?.winner || `Winner Match ${i * 2 + 2}`;

                    let matchObj = { id: `${stage.target}-M${i+1}`, t1: t1, t2: t2, g1: null, g2: null, winner: null, suffix: "", played: false };

                    let isPlaceholderA = t1.startsWith("Winner") || t1.startsWith("Runner") || t1.includes("Match");
                    let isPlaceholderB = t2.startsWith("Winner") || t2.startsWith("Runner") || t2.includes("Match");

                    if (simulateUnplayedNodes && !isPlaceholderA && !isPlaceholderB) {
                        let res = calculatePoissonExpectancyGoalsProbabilities(t1, t2, true);
                        Object.assign(matchObj, res, { played: true });
                    }
                    knockoutBracketNodes[stage.target].push(matchObj);
                }
            });
        }

