        /* ==========================================================================
           H. TACTICAL BLACKBOARD ARCHITECTURE ENGINE IMPLEMENTATION VISUALS
           ========================================================================== */
        function extractSquadRosterManifest(teamKeyNameString) {
            if(RAW_ROSTERS[teamKeyNameString]) return RAW_ROSTERS[teamKeyNameString];
            // Fallback dynamically generated standard roster list variables matrices if not explicit
            let fallbackRosterArray = [{ name: "P. Keeper", pos: "GK" }];
