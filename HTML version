        function calculatePoissonExpectancyGoalsProbabilities(teamA, teamB, typeIsKnockout = false) {
            let m1 = TEAM_METRICS[teamA] || { elo: 1800, att: 78, def: 78, clutch: 0.78 };
            let m2 = TEAM_METRICS[teamB] || { elo: 1800, att: 78, def: 78, clutch: 0.78 };

            // Base rating score metrics calculation matrices functions transformations equations
            let eloDifferenceScalar = (m1.elo - m2.elo) / 400;
            let baseExpectedRatioA = 1.35 + (eloDifferenceScalar * 0.5);
            let baseExpectedRatioB = 1.35 - (eloDifferenceScalar * 0.5);

            // Factor capability attribute scales indicators lines vectors adjustments
            let attackDefenseVectorRatioA = (m1.att / m2.def) * 0.95;
            let attackDefenseVectorRatioB = (m2.att / m1.def) * 0.95;

            let lambdaValueA = Math.max(0.2, baseExpectedRatioA * attackDefenseVectorRatioA);
            let lambdaValueB = Math.max(0.2, baseExpectedRatioB * attackDefenseVectorRatioB);

            // Apply stochastic variance parameters loops noise ranges
            let goalsScoredA = drawPoissonRandomVariableSample(lambdaValueA);
            let goalsScoredB = drawPoissonRandomVariableSample(lambdaValueB);

            // Resolve penalty tie-breaker contingencies parameters sets if mandatory
            let penaltyWinnerString = null;
            if(typeIsKnockout && goalsScoredA === goalsScoredB) {
                // Determine odds tracking clutch variables weights matrices ratios profiles
                let totalClutchWeight = m1.clutch + m2.clutch;
                let randomRollThreshold = Math.random() * totalClutchWeight;
                penaltyWinnerString = (randomRollThreshold <= m1.clutch) ? teamA : teamB;
            }

            return {
                g1: goalsScoredA,
                g2: goalsScoredB,
                winner: goalsScoredA > goalsScoredB ? teamA : (goalsScoredB > goalsScoredA ? teamB : penaltyWinnerString),
                suffix: penaltyWinnerString ? " (PEN)" : ""
            };
        }

        function drawPoissonRandomVariableSample(lambda) {
            let limitCheckVal = Math.exp(-lambda);
            let kCounter = 0;
            let pWeightProd = 1.0;
            do {
                kCounter++;
                pWeightProd *= Math.random();
            } while (pWeightProd > limitCheckVal);
            return kCounter - 1;
        }

