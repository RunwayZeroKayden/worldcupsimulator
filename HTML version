<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>World Football Tournament Simulation Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Orbitron:wght@600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* ==========================================================================
           1. CSS CORE VARIABLES & NEON DIGITAL SPORTS THEME
           ========================================================================== */
        :root {
            --bg-global: #0b0f19;
            --bg-sidebar: #0f172a;
            --bg-card: #1e293b;
            --bg-card-header: #111827;
            --bg-input: #334155;
            
            --accent-primary: #38bdf8;
            --accent-primary-hover: #0ea5e9;
            --accent-secondary: #a855f7;
            --accent-success: #22c55e;
            --accent-danger: #ef4444;
            --accent-warning: #f59e0b;
            
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --text-dark: #0f172a;
            --border-color: #334155;
            --pitch-grass: #15803d;
            --pitch-lines: rgba(255, 255, 255, 0.6);
            
            --font-sans: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --font-sports: 'Orbitron', sans-serif;
            
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --transition-speed: 0.2s;
        }

        /* ==========================================================================
           2. GLOBAL RESET & BASE LAYOUT HIERARCHY
           ========================================================================== */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-sans);
            background-color: var(--bg-global);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
            line-height: 1.5;
        }

        header {
            background-color: var(--bg-sidebar);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow-md);
            z-index: 10;
        }

        .header-title-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .header-title-container i {
            font-size: 2rem;
            color: var(--accent-primary);
            filter: drop-shadow(0 0 8px rgba(56, 189, 248, 0.4));
        }

        .header-title-container h1 {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, var(--text-main) 30%, var(--accent-primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .global-control-panel {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        /* ==========================================================================
           3. BUTTONS & UI COMPONENT STYLING
           ========================================================================== */
        .btn {
            font-family: var(--font-sans);
            font-weight: 600;
            font-size: 0.875rem;
            padding: 0.625rem 1.25rem;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all var(--transition-speed) ease;
            box-shadow: var(--shadow-sm);
        }

        .btn-primary {
            background-color: var(--accent-primary);
            color: var(--text-dark);
        }

        .btn-primary:hover {
            background-color: var(--accent-primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 0 12px rgba(56, 189, 248, 0.3);
        }

        .btn-primary:disabled {
            background-color: var(--bg-input);
            color: var(--text-muted);
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .btn-secondary {
            background-color: var(--accent-secondary);
            color: var(--text-main);
        }

        .btn-secondary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-success {
            background-color: var(--accent-success);
            color: var(--text-dark);
        }

        .btn-success:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-danger {
            background-color: var(--accent-danger);
            color: var(--text-main);
        }

        .btn-danger:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        /* ==========================================================================
           4. TAB NAVIGATION LAYOUT CONFIGURATION
           ========================================================================== */
        .tab-navigator-container {
            background-color: var(--bg-sidebar);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            padding: 0 2rem;
            gap: 4px;
            overflow-x: auto;
        }

        .tab-button {
            background: none;
            border: none;
            color: var(--text-muted);
            font-family: var(--font-sans);
            font-weight: 600;
            font-size: 0.9rem;
            padding: 1rem 1.25rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            border-bottom: 3px solid transparent;
            transition: all var(--transition-speed) ease;
            white-space: nowrap;
        }

        .tab-button:hover {
            color: var(--text-main);
            background-color: rgba(255, 255, 255, 0.02);
        }

        .tab-button.active {
            color: var(--accent-primary);
            border-bottom-color: var(--accent-primary);
            background-color: rgba(56, 189, 248, 0.05);
        }

        .main-content-canvas {
            flex: 1;
            padding: 2rem;
            position: relative;
            overflow-y: auto;
        }

        .tab-view-panel {
            display: none;
            animation: fadeIn 0.3s ease-in-out;
        }

        .tab-view-panel.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(4px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ==========================================================================
           5. GROUP STAGE INTERACTIVE LAYOUT BLOCKS
           ========================================================================== */
        .group-stage-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
            gap: 1.5rem;
        }

        .group-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: var(--shadow-md);
            display: flex;
            flex-direction: column;
        }

        .group-card-header {
            background-color: var(--bg-card-header);
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .group-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--accent-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .group-card-actions {
            display: flex;
            gap: 6px;
        }

        .btn-mini {
            padding: 4px 8px;
            font-size: 0.75rem;
            border-radius: 4px;
        }

        .group-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.825rem;
            text-align: left;
        }

        .group-table th, .group-table td {
            padding: 0.5rem 0.75rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .group-table th {
            background-color: rgba(0, 0, 0, 0.15);
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.5px;
        }

        .group-table tr:last-child td {
            border-bottom: none;
        }

        .team-cell {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
        }

        .flag-icon {
            width: 20px;
            height: 14px;
            object-fit: cover;
            border-radius: 2px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.2);
            background-color: #334155;
        }

        .advancing-1st { border-left: 3px solid var(--accent-success); }
        .advancing-2nd { border-left: 3px solid var(--accent-primary); }
        .advancing-3rd { border-left: 3px solid var(--accent-warning); }

        .group-matchups-container {
            border-top: 1px dashed var(--border-color);
            padding: 0.75rem 1rem;
            background-color: rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            gap: 6px;
            max-height: 160px;
            overflow-y: auto;
        }

        .match-row-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
            padding: 4px 0;
        }

        .match-teams-block {
            display: flex;
            align-items: center;
            gap: 6px;
            width: 65%;
        }

        .match-team-name {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .match-vs-divider {
            color: var(--text-muted);
            font-size: 0.7rem;
            margin: 0 4px;
        }

        .match-score-inputs-block {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .score-input {
            width: 28px;
            height: 22px;
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            text-align: center;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: 700;
            border-radius: 3px;
        }

        .score-input:focus {
            outline: none;
            border-color: var(--accent-primary);
        }

        .score-input.manual-override {
            background-color: rgba(168, 85, 247, 0.2);
            border-color: var(--accent-secondary);
        }

        .score-input.simulated-value {
            color: var(--accent-primary);
        }

        .match-incidents-summary {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-align: right;
            width: 15%;
            white-space: nowrap;
        }

        /* ==========================================================================
           6. WILDCARD SANDBOX STRUCTURES
           ========================================================================== */
        .wildcard-explanation-box {
            background-color: rgba(56, 189, 248, 0.05);
            border: 1px solid rgba(56, 189, 248, 0.2);
            border-radius: 6px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
        }

        .wildcard-table-wrapper {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: var(--shadow-lg);
            max-width: 900px;
            margin: 0 auto;
        }

        .status-badge {
            font-size: 0.7rem;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 4px;
            text-transform: uppercase;
        }

        .status-badge-advance {
            background-color: rgba(34, 197, 94, 0.15);
            color: var(--accent-success);
        }

        .status-badge-eliminated {
            background-color: rgba(239, 68, 68, 0.15);
            color: var(--accent-danger);
        }

        /* ==========================================================================
           7. VISUAL KNOCKOUT TREE DESIGN BRACKET
           ========================================================================== */
        .bracket-scroll-viewport {
            width: 100%;
            overflow-x: auto;
            padding: 1rem 0;
        }

        .bracket-tree-canvas {
            display: flex;
            gap: 2.5rem;
            min-width: 1400px;
            justify-content: space-between;
            position: relative;
            padding: 20px;
        }

        .bracket-column-stage {
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            flex: 1;
            min-width: 220px;
        }

        .bracket-stage-header {
            text-align: center;
            font-family: var(--font-sports);
            font-size: 0.8rem;
            letter-spacing: 1px;
            color: var(--accent-primary);
            margin-bottom: 1rem;
            background-color: var(--bg-sidebar);
            padding: 6px;
            border-radius: 4px;
            border: 1px solid var(--border-color);
        }

        .bracket-match-node {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            overflow: hidden;
            margin: 10px 0;
            box-shadow: var(--shadow-md);
            position: relative;
            transition: transform var(--transition-speed);
        }

        .bracket-match-node:hover {
            transform: scale(1.02);
            border-color: var(--accent-primary);
            z-index: 5;
        }

        .node-team-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem;
            font-size: 0.8rem;
            border-bottom: 1px solid rgba(255,255,255,0.03);
            height: 36px;
        }

        .node-team-row:last-child {
            border-bottom: none;
        }

        .node-team-info {
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 500;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
        }

        .node-team-score-badge {
            background-color: rgba(0,0,0,0.2);
            font-family: var(--font-mono);
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 3px;
            min-width: 24px;
            text-align: center;
        }

        .node-team-row.winner-highlight {
            background-color: rgba(34, 197, 94, 0.08);
            color: #fff;
            font-weight: 700;
        }

        .node-team-row.winner-highlight .node-team-score-badge {
            background-color: var(--accent-success);
            color: var(--text-dark);
        }

        .match-meta-suffix {
            font-size: 0.65rem;
            color: var(--accent-secondary);
            font-family: var(--font-mono);
            text-align: center;
            background-color: rgba(0,0,0,0.15);
            padding: 2px 0;
            border-top: 1px solid rgba(255,255,255,0.03);
        }

        .grand-final-node {
            border: 2px dashed var(--accent-warning);
            box-shadow: 0 0 15px rgba(245, 158, 11, 0.2);
        }

        .grand-final-node .bracket-stage-header {
            background-color: rgba(245, 158, 11, 0.1);
            color: var(--accent-warning);
            border-color: var(--accent-warning);
        }

        /* ==========================================================================
           8. MONTE CARLO ANALYTICS GRID & TABLES
           ========================================================================== */
        .analytics-control-dashboard {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.25rem;
            margin-bottom: 1.5rem;
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem;
            align-items: center;
        }

        .control-input-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .control-input-group label {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .select-input, .text-field-input {
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            font-family: var(--font-sans);
            font-size: 0.9rem;
            min-width: 160px;
        }

        .select-input:focus, .text-field-input:focus {
            outline: none;
            border-color: var(--accent-primary);
        }

        .simulation-progress-track {
            flex: 1;
            min-width: 250px;
            display: none;
        }

        .progress-bar-container {
            width: 100%;
            height: 10px;
            background-color: rgba(0,0,0,0.3);
            border-radius: 5px;
            overflow: hidden;
            border: 1px solid var(--border-color);
            margin-top: 4px;
        }

        .progress-bar-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--accent-secondary), var(--accent-primary));
            transition: width 0.1s linear;
        }

        .analytics-results-wrapper {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: var(--shadow-lg);
        }

        .analytics-search-box {
            padding: 1rem;
            background-color: var(--bg-card-header);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .analytics-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
            text-align: left;
        }

        .analytics-table th, .analytics-table td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .analytics-table th {
            background-color: rgba(0, 0, 0, 0.2);
            color: var(--text-muted);
            font-weight: 600;
            cursor: pointer;
            user-select: none;
        }

        .analytics-table th:hover {
            color: var(--text-main);
            background-color: rgba(0, 0, 0, 0.3);
        }

        .analytics-table th i {
            margin-left: 4px;
            font-size: 0.75rem;
        }

        .analytics-table tr:hover td {
            background-color: rgba(255, 255, 255, 0.02);
        }

        .probability-bar-track {
            width: 100%;
            height: 6px;
            background-color: rgba(0,0,0,0.2);
            border-radius: 3px;
            overflow: hidden;
            margin-top: 4px;
        }

        .probability-bar-fill {
            height: 100%;
            border-radius: 3px;
        }

        /* ==========================================================================
           9. TACTICAL BLACKBOARD INTERACTIVE ENGINE
           ========================================================================== */
        .tactical-split-layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 2rem;
            align-items: start;
        }

        .tactical-control-panel {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .tactical-slider-container {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .tactical-slider-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
        }

        .tactical-slider {
            width: 100%;
            accent-color: var(--accent-primary);
            cursor: pointer;
        }

        .pitch-viewport-canvas {
            background-color: var(--pitch-grass);
            border: 4px solid #ffffff;
            border-radius: 12px;
            height: 520px;
            max-width: 460px;
            margin: 0 auto;
            position: relative;
            box-shadow: inset 0 0 40px rgba(0,0,0,0.4), var(--shadow-lg);
            overflow: hidden;
        }

        .pitch-half-line {
            position: absolute;
            top: 50%;
            left: 0;
            width: 100%;
            height: 2px;
            background-color: var(--pitch-lines);
        }

        .pitch-center-circle {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 110px;
            height: 110px;
            border: 2px solid var(--pitch-lines);
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }

        .pitch-center-spot {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 6px;
            height: 6px;
            background-color: #ffffff;
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }

        .pitch-penalty-box-top {
            position: absolute;
            top: 0;
            left: 50%;
            width: 220px;
            height: 80px;
            border: 2px solid #ffffff;
            border-top: none;
            transform: translateX(-50%);
        }

        .pitch-penalty-box-bottom {
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 220px;
            height: 80px;
            border: 2px solid #ffffff;
            border-bottom: none;
            transform: translateX(-50%);
        }

        .pitch-player-node {
            position: absolute;
            width: 48px;
            text-align: center;
            transform: translate(-50%, -50%);
            z-index: 2;
            transition: all 0.4s ease-out;
            cursor: grab;
        }

        .player-node-icon-wrapper {
            position: relative;
            width: 32px;
            height: 32px;
            background-color: var(--bg-sidebar);
            border: 2px solid var(--accent-primary);
            border-radius: 50%;
            margin: 0 auto 4px auto;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-md);
        }

        .player-node-rating-badge {
            position: absolute;
            bottom: -6px;
            right: -6px;
            background-color: var(--accent-secondary);
            color: #fff;
            font-size: 0.6rem;
            font-weight: 800;
            padding: 1px 3px;
            border-radius: 50%;
            border: 1px solid var(--bg-sidebar);
        }

        .player-node-name-string {
            font-size: 0.65rem;
            font-weight: 700;
            color: #ffffff;
            text-shadow: 0 1px 3px rgba(0,0,0,0.8);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            background-color: rgba(15, 23, 42, 0.6);
            padding: 1px 4px;
            border-radius: 3px;
        }

        .incident-overlay-badge {
            position: absolute;
            top: -10px;
            left: -6px;
            font-size: 0.9rem;
            z-index: 10;
        }

        /* ==========================================================================
           10. LIVE TEXT INCIDENT LOG PANEL & METRIC STREAM
           ========================================================================== */
        .logs-split-dashboard {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 1.5rem;
            height: calc(100vh - 180px);
            min-height: 550px;
        }

        .log-stream-terminal-wrapper {
            background-color: #020617;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.6);
        }

        .terminal-header-bar {
            background-color: var(--bg-card-header);
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .terminal-status-light {
            display: inline-block;
            width: 8px;
            height: 8px;
