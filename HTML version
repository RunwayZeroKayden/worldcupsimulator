        /* ==========================================================================
           6. EVENT REGISTRATION HANDLERS AND UI SYNCHRONIZERS
           ========================================================================== */
        function registerManualScoreOverride(mKey, teamIndex, value) {
            let parsedVal = parseInt(value);
            if (isNaN(parsedVal)) {
                if (manualScoreOverrides[mKey]) {
                    delete manualScoreOverrides[mKey];
                }
            } else {
                if (!manualScoreOverrides[mKey]) {
                    manualScoreOverrides[mKey] = { g1: 0, g2: 0, suffix: "", simulated: false };
                }
                if (teamIndex === 1) manualScoreOverrides[mKey].g1 = parsedVal;
                if (teamIndex === 2) manualScoreOverrides[mKey].g2 = parsedVal;
                manualScoreOverrides[mKey].simulated = false;
            }
            tournamentHasUpdatedState = true;
        }

        function simulateIndividualGroupPhase(gId) {
            let schedules = buildGroupMatchupsSchedule(gId);
            schedules.forEach(mKey => {
                let { t1, t2 } = unpackMatchKeyMetadata(mKey);
                let out = runMatchSimulationCore(t1, t2, true, false);
                manualScoreOverrides[mKey] = { g1: out.g1, g2: out.g2, suffix: out.suffix, simulated: true };
                out.incidents.forEach(ev => appendTerminalLogMessage(ev.desc, ev.type));
            });
            runMasterCalculationPipeline(false);
        }

        function appendTerminalLogMessage(text, styleClass = "") {
            const box = document.getElementById("terminal-scroll-area-target");
            let row = document.createElement("div");
            row.className = `terminal-line-string line-${styleClass}`;
            row.innerText = text;
            box.appendChild(row);
            box.scrollTop = box.scrollHeight;
        }

        function refreshStatusBoardWidgets() {
            const ward = document.getElementById("injury-ward-target");
            ward.innerHTML = "";
            let injKeys = Object.keys(injuryWardRegistry);
            if (injKeys.length === 0) {
                ward.innerHTML = `<li style="color:var(--text-muted); font-size:0.75rem;">No active tournament injuries.</li>`;
            } else {
                injKeys.forEach(p => {
                    let obj = injuryWardRegistry[p];
                    ward.innerHTML += `<li class="ward-item-row"><b>${p}</b> <span style="color:var(--accent-danger); font-size:0.7rem;"><i class="fa-solid fa-house-medical-flag"></i> ${FIFA_CODES[obj.team]}</span></li>`;
