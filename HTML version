            // Generate standard numbers of players per positions array
            const structuralQuantities = { "GK": 2, "DF": 5, "MF": 5, "AT": 4 };
            
            for (let pos of POSITION_KEYS) {
                let limit = structuralQuantities[pos];
                for (let i = 0; i < limit; i++) {
                    let variance = ((seed * (i + 1) * 7) % 11) - 5;
                    let pRating = Math.max(60, Math.min(94, baseRating + variance));
                    let tier = "WISSEL";
                    if (pRating > 86) tier = "STAR";
                    else if (pRating > 80) tier = "STARTER";
                    else if (pRating < 72) tier = "RESERVE";
                    
                    let nameIdx = (seed + pos.charCodeAt(0) + i) % FAMILY_NAMES.length;
                    let player_fullname = `P. ${FAMILY_NAMES[nameIdx]}`;
                    generatedRoster[pos].push([player_fullname, tier, pRating]);
                }
            }
            return generatedRoster;
        }

        /* ==========================================================================
           3. CORE MATCH ENGINE LOGIC (POISSON GENERATOR FUNCTIONS)
           ========================================================================== */
        function calculatePoissonValue(lambda) {
            let L = Math.exp(-lambda);
            let k = 0;
            let p = 1.0;
            do {
                k++;
                p *= Math.random();
            } while (p > L && k < 12);
            return k - 1;
        }

        function runMatchSimulationCore(team1, team2, canDraw = true, isMonteCarloPass = false) {
            const m1 = TEAM_METRICS[team1] || { ELO: 1500, PELE: 1500 };
            const m2 = TEAM_METRICS[team2] || { ELO: 1500, PELE: 1500 };
            
            const rawDelta = m1.ELO - m2.ELO;
            let upsetFactor = Math.max(0.4, Math.min(1.6, 1.0 + (rawDelta / 800.0)));
            
            let off1 = m1.PELE / 1000.0;
            let def1 = m1.ELO / 1000.0;
            let off2 = m2.PELE / 1000.0;
            let def2 = m2.ELO / 1000.0;
            
            let lam1 = 1.15 * upsetFactor * (off1 / def2);
            let lam2 = 1.15 * (2.0 - upsetFactor) * (off2 / def1);
            
            // Inject potential engine modifications derived from tactical positions arrays
            if (team1 === activeTacticalTeamString && !isMonteCarloPass) {
                const settings = readBlackboardUIAttributes();
                lam1 *= (settings.tempo / 50.0);
                lam2 /= (settings.depth / 50.0);
            }
            if (team2 === activeTacticalTeamString && !isMonteCarloPass) {
                const settings = readBlackboardUIAttributes();
                lam2 *= (settings.tempo / 50.0);
                lam1 /= (settings.depth / 50.0);
            }

            let g1 = calculatePoissonValue(Math.max(0.05, lam1));
            let g2 = calculatePoissonValue(Math.max(0.05, lam2));
            
            let winner = "Draw";
            let suffix = "";
            let outcome_incidents = [];
            
            if (g1 > g2) winner = team1;
            else if (g2 > g1) winner = team2;
            
            // Handle knock-out tie-breaking mandates
            if (!canDraw && g1 === g2) {
                let extra_g1 = calculatePoissonValue(lam1 * 0.35);
                let extra_g2 = calculatePoissonValue(lam2 * 0.35);
                g1 += extra_g1;
                g2 += extra_g2;
                suffix = " (AET)";
                
                if (g1 > g2) winner = team1;
                else if (g2 > g1) winner = team2;
                else {
                    // Penalty Shootouts Simulation Routing
                    let p1 = 3 + Math.floor(Math.random() * 3);
                    let p2 = 3 + Math.floor(Math.random() * 3);
                    if (p1 === p2) {
                        if (Math.random() > 0.5) p1++; else p2++;
                    }
                    winner = p1 > p2 ? team1 : team2;
                    suffix = ` (${p1}-${p2} Pens)`;
                }
            }

            // Foreground Simulation Pass: Compute and generate descriptive event records
            if (!isMonteCarloPass) {
                generateMatchIncidentsDataManifest(team1, team2, g1, g2, outcome_incidents);
            }
            
            return { g1, g2, winner, suffix, incidents: outcome_incidents };
        }

        function generateMatchIncidentsDataManifest(t1, t2, g1, g2, arr) {
            const roster1 = extractSquadRosterManifest(t1);
            const roster2 = extractSquadRosterManifest(t2);
            
            // Goal Event Mapping
            for (let i = 0; i < g1; i++) {
                let min = Math.floor(Math.random() * 90) + 1;
                let pool = roster1.AT.concat(roster1.MF);
                let scorer = pool[Math.floor(Math.random() * pool.length)][0];
                arr.push({ type: 'goal', min, team: t1, player: scorer, desc: `⚽ Goal! [${min}'] ${scorer} scores for ${t1}!` });
                playerScoringRegistry[scorer] = (playerScoringRegistry[scorer] || 0) + 1;
            }
            for (let i = 0; i < g2; i++) {
                let min = Math.floor(Math.random() * 90) + 1;
                let pool = roster2.AT.concat(roster2.MF);
                let scorer = pool[Math.floor(Math.random() * pool.length)][0];
                arr.push({ type: 'goal', min, team: t2, player: scorer, desc: `⚽ Goal! [${min}'] ${scorer} scores for ${t2}!` });
                playerScoringRegistry[scorer] = (playerScoringRegistry[scorer] || 0) + 1;
            }
            
            // Disciplinary Card Generator Rolls
            if (Math.random() < 0.4) {
                let min = Math.floor(Math.random() * 85) + 5;
                let targetTeam = Math.random() > 0.5 ? t1 : t2;
                let ros = targetTeam === t1 ? roster1.DF : roster2.DF;
                let p = ros[Math.floor(Math.random() * ros.length)][0];
                if (Math.random() > 0.85) {
                    arr.push({ type: 'red', min, team: targetTeam, player: p, desc: `🟥 Red Card! [${min}'] ${p} (${targetTeam}) dismissed!` });
                    suspensionWardRegistry[p] = (suspensionWardRegistry[p] || 0) + 1;
                } else {
                    arr.push({ type: 'yellow', min, team: targetTeam, player: p, desc: `🟨 Yellow Card! [${min}'] ${p} (${targetTeam}) warned.` });
                }
            }

            // Injury Generator Rolls
            if (Math.random() < 0.12) {
                let min = Math.floor(Math.random() * 80) + 1;
                let targetTeam = Math.random() > 0.5 ? t1 : t2;
                let pool = targetTeam === t1 ? roster1.MF.concat(roster1.AT) : roster2.MF.concat(roster2.AT);
                let p = pool[Math.floor(Math.random() * pool.length)][0];
                arr.push({ type: 'injury', min, team: targetTeam, player: p, desc: `🚑 Injury! [${min}'] ${p} (${targetTeam}) forced off.` });
                injuryWardRegistry[p] = { team: targetTeam, status: "Treatment Active" };
            }
        }

        /* ==========================================================================
           4. TOURNAMENT COMPILER AND PIPELINE SCHEDULERS
           ========================================================================== */
        function runMasterCalculationPipeline(isReactiveSimulationPass = false) {
            // Step 1: Compute group standings maps
            for (let gId in GROUPS) {
                let teams = GROUPS[gId];
                let table = {};
                teams.forEach(t => { table[t] = { name: t, pld: 0, w: 0, d: 0, l: 0, gf: 0, ga: 0, gd: 0, pts: 0, group: gId }; });
                
                let schedules = buildGroupMatchupsSchedule(gId);
                schedules.forEach(mKey => {
                    let { t1, t2 } = unpackMatchKeyMetadata(mKey);
                    let s1, s2;
                    
                    if (manualScoreOverrides[mKey] !== undefined) {
                        s1 = manualScoreOverrides[mKey].g1;
                        s2 = manualScoreOverrides[mKey].g2;
                    } else if (isReactiveSimulationPass) {
                        let simResult = runMatchSimulationCore(t1, t2, true, false);
                        s1 = simResult.g1;
                        s2 = simResult.g2;
                        manualScoreOverrides[mKey] = { g1: s1, g2: s2, suffix: simResult.suffix, simulated: true };
                        simResult.incidents.forEach(ev => appendTerminalLogMessage(ev.desc, ev.type));
                    } else {
                        s1 = 0; s2 = 0; // Baseline init value
                    }
                    
                    // Accumulate group structural scores metrics
                    table[t1].pld++; table[t2].pld++;
                    table[t1].gf += s1; table[t1].ga += s2;
                    table[t2].gf += s2; table[t2].ga += s1;
                    table[t1].gd = table[t1].gf - table[t1].ga;
                    table[t2].gd = table[t2].gf - table[t2].ga;
                    
                    if (s1 > s2) { table[t1].pts += 3; table[t1].w++; table[t2].l++; }
                    else if (s2 > s1) { table[t2].pts += 3; table[t2].w++; table[t1].l++; }
                    else { table[t1].pts += 1; table[t2].pts += 1; table[t1].d++; table[t2].d++; }
                });

                // Tier break group arrays sorting mapping configurations
                groupStandingsMap[gId] = Object.values(table).sort((a, b) => {
                    if (b.pts !== a.pts) return b.pts - a.pts;
                    if (b.gd !== a.gd) return b.gd - a.gd;
                    if (b.gf !== a.gf) return b.gf - a.gf;
                    return (TEAM_METRICS[b.name]?.ELO || 0) - (TEAM_METRICS[a.name]?.ELO || 0);
                });
            }

            // Step 2: Extract and evaluate wildcard records
            calculateThirdPlaceWildcardsManifest();

            // Step 3: Compile layout trees for active knock-out phase positions
            compileKnockoutBracketDataTree(isReactiveSimulationPass);

            // Trigger structural rendering functions updates
            if (!isReactiveSimulationPass) {
                renderGroupStageCardsLayout();
                renderWildcardSandboxMatrix();
                renderVisualKnockoutTree();
                refreshStatusBoardWidgets();
            }
        }

        function calculateThirdPlaceWildcardsManifest() {
            let thirdsList = [];
            for (let gId in groupStandingsMap) {
                if (groupStandingsMap[gId][2]) {
                    thirdsList.push(groupStandingsMap[gId][2]);
                }
            }
            
            // Sort Third place teams across the 12 pools
            thirdsList.sort((a, b) => {
                if (b.pts !== a.pts) return b.pts - a.pts;
                if (b.gd !== a.gd) return b.gd - a.gd;
                if (b.gf !== a.gf) return b.gf - a.gf;
                return (TEAM_METRICS[b.name]?.ELO || 0) - (TEAM_METRICS[a.name]?.ELO || 0);
            });
            
            wildcardStandingsList = thirdsList;
        }

        function compileKnockoutBracketDataTree(isSimPass) {
            let advancing1st = [];
            let advancing2nd = [];
            let advancing3rd = [];
            
            for (let gId in groupStandingsMap) {
                if (groupStandingsMap[gId][0]) advancing1st.push(groupStandingsMap[gId][0].name);
                if (groupStandingsMap[gId][1]) advancing2nd.push(groupStandingsMap[gId][1].name);
            }
            
            for (let i = 0; i < wildcardStandingsList.length; i++) {
                if (i < 8) advancing3rd.push(wildcardStandingsList[i].name);
            }

            // Initialize or clear Round of 32 node mappings layout array configurations
            knockoutBracketNodes = {
                "R32": [], "R16": [], "QF": [], "SF": [], "Final": [], "Champion": []
            };

            // Structure deterministic pairings for R32
            for (let i = 0; i < 16; i++) {
                let t1 = advancing1st[i] || `Winner Pool ${String.fromCharCode(65 + i)}`;
                let t2 = "TBD";
                
                if (i < 8) {
                    t2 = advancing3rd[i] || `Wildcard #${i + 1}`;
                } else {
                    t2 = advancing2nd[i - 8] || `Runner-up Pool ${String.fromCharCode(65 + i - 8)}`;
                }
                
                let matchResult = { team1: t1, team2: t2, score1: null, score2: null, winner: null, meta: "" };
                if (isSimPass && advancing1st[i] && t2 !== "TBD") {
                    let out = runMatchSimulationCore(t1, t2, false, false);
                    matchResult.score1 = out.g1; matchResult.score2 = out.g2;
                    matchResult.winner = out.winner; matchResult.meta = out.suffix;
                    out.incidents.forEach(ev => appendTerminalLogMessage(ev.desc, ev.type));
                }
                knockoutBracketNodes.R32.push(matchResult);
            }

            // Recurse structural derivations for subsequent stages
            resolveSubsequentKnockoutStages(isSimPass);
        }

        function resolveSubsequentKnockoutStages(isSimPass) {
            const stagesOrderList = [
                { source: "R32", target: "R16", sets: 8 },
                { source: "R16", target: "QF", sets: 4 },
                { source: "QF", target: "SF", sets: 2 },
                { source: "SF", target: "Final", sets: 1 }
            ];

            stagesOrderList.forEach(stage => {
                for (let i = 0; i < stage.sets; i++) {
                    let leftNode = knockoutBracketNodes[stage.source][i * 2];
                    let rightNode = knockoutBracketNodes[stage.source][i * 2 + 1];
                    
                    let t1 = leftNode?.winner || `Winner Match ${i * 2 + 1}`;
                    let t2 = rightNode?.winner || `Winner Match ${i * 2 + 2}`;
                    
                    let matchResult = { team1: t1, team2: t2, score1: null, score2: null, winner: null, meta: "" };
                    
                    if (isSimPass && leftNode?.winner && rightNode?.winner) {
                        let out = runMatchSimulationCore(t1, t2, false, false);
                        matchResult.score1 = out.g1; matchResult.score2 = out.g2;
                        matchResult.winner = out.winner; matchResult.meta = out.suffix;
                        out.incidents.forEach(ev => appendTerminalLogMessage(ev.desc, ev.type));
                    }
                    knockoutBracketNodes[stage.target].push(matchResult);
                }
            });

            // Crown Champion
            let finalMatch = knockoutBracketNodes.Final[0];
            if (finalMatch?.winner) {
                knockoutBracketNodes.Champion.push(finalMatch.winner);
                if (isSimPass) {
                    appendTerminalLogMessage(`🏆 TOURNAMENT CHAMPION CHAMPION: ${finalMatch.winner} has claimed the tournament trophy!`, 'header');
                }
            } else {
                knockoutBracketNodes.Champion.push("TBD");
            }
        }

        /* ==========================================================================
           5. RENDERING PIPELINES AND UTILITIES FUNCTIONS
           ========================================================================== */
        function getCountryFlagURLElement(team) {
            let iso = ISO_CODES[team] || "un";
            return `<img src="https://flagcdn.com/w20/${iso}.png" class="flag-icon" onerror="this.src='https://flagcdn.com/w20/un.png';" alt="${team}">`;
        }

        function buildGroupMatchupsSchedule(gId) {
            let teams = GROUPS[gId];
            return [
                `g_${gId}_${teams[0]}_vs_${teams[1]}`,
                `g_${gId}_${teams[2]}_vs_${teams[3]}`,
                `g_${gId}_${teams[0]}_vs_${teams[2]}`,
                `g_${gId}_${teams[3]}_vs_${teams[1]}`,
                `g_${gId}_${teams[1]}_vs_${teams[2]}`,
                `g_${gId}_${teams[3]}_vs_${teams[0]}`
            ];
        }

        function unpackMatchKeyMetadata(mKey) {
            let chunks = mKey.split("_vs_");
            let part1 = chunks[0].split("_");
            let t1 = part1[2];
            let t2 = chunks[1];
            return { gId: part1[1], t1, t2 };
        }

