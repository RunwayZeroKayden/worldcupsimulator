        /* ==========================================================================
           8. STOCHASTIC STOCHASTIC MONTE CARLO ENGINE CORE PIPELINE
           ========================================================================== */
        function triggerMonteCarloCalculationsPipeline() {
            const iterations = parseInt(document.getElementById("select-mc-iterations").value);
            const progressWrapper = document.getElementById("mc-progress-wrapper");
            const bar = document.getElementById("mc-progress-bar-fill");
            const txtPct = document.getElementById("mc-progress-pct");
            
            progressWrapper.style.display = "block";
            bar.style.width = "0%";
            txtPct.innerText = "0%";

            // Initialize global analytic tracking objects arrays data
            let aggregates = {};
            Object.keys(TEAM_METRICS).forEach(t => {
                aggregates[t] = { team: t, groupWin: 0, r32: 0, r16: 0, qf: 0, sf: 0, final: 0, trophy: 0 };
            });

            let completed = 0;
            // Execute chunk processing routines via timeouts to maintain responsive operational frames
            function processSimulationBatchChunk() {
                let chunkLimit = Math.min(50, iterations - completed);
                for (let count = 0; count < chunkLimit; count++) {
                    executeSinglePassMonteCarloLoop(aggregates);
                }
                completed += chunkLimit;
                
                let pct = Math.round((completed / iterations) * 100);
                bar.style.width = `${pct}%`;
                txtPct.innerText = `${pct}%`;
                
                if (completed < iterations) {
                    setTimeout(processSimulationBatchChunk, 1);
                } else {
                    // Normalize tracking data records array format values against total count scale
                    globalAnalyticsCollection = Object.values(aggregates).map(item => {
                        return {
                            team: item.team,
                            groupWin: (item.groupWin / iterations) * 100,
                            r32: (item.r32 / iterations) * 100,
                            r16: (item.r16 / iterations) * 100,
                            qf: (item.qf / iterations) * 100,
                            sf: (item.sf / iterations) * 100,
                            final: (item.final / iterations) * 100,
                            trophy: (item.trophy / iterations) * 100
                        };
                    });
                    
                    progressWrapper.style.display = "none";
                    sortAndRenderAnalyticsGrid();
                }
            }
            setTimeout(processSimulationBatchChunk, 5);
        }

        function executeSinglePassMonteCarloLoop(agg) {
            let localStandings = {};
            
            // Loop step 1: Groups stage matrices calculation
            for (let gId in GROUPS) {
                let teams = GROUPS[gId];
                let table = {};
                teams.forEach(t => { table[t] = { name: t, pts: 0, gd: 0, gf: 0, group: gId }; });
                
                let schedules = buildGroupMatchupsSchedule(gId);
                schedules.forEach(mKey => {
                    let { t1, t2 } = unpackMatchKeyMetadata(mKey);
                    let s1, s2;
                    
                    // Note: Monte Carlo analysis overrides manual adjustments to evaluate raw statistical baseline odds
                    let sim = runMatchSimulationCore(t1, t2, true, true);
                    s1 = sim.g1; s2 = sim.g2;
                    
                    table[t1].gf += s1; table[t1].ga += s2;
                    table[t2].gf += s2; table[t2].ga += s1;
                    table[t1].gd += (s1 - s2);
                    table[t2].gd += (s2 - s1);
                    
                    if (s1 > s2) { table[t1].pts += 3; }
                    else if (s2 > s1) { table[t2].pts += 3; }
                    else { table[t1].pts += 1; table[t2].pts += 1; }
                });

                localStandings[gId] = Object.values(table).sort((a, b) => {
                    if (b.pts !== a.pts) return b.pts - a.pts;
                    if (b.gd !== a.gd) return b.gd - a.gd;
                    if (b.gf !== a.gf) return b.gf - a.gf;
                    return (TEAM_METRICS[b.name]?.ELO || 0) - (TEAM_METRICS[a.name]?.ELO || 0);
                });
            }

            // Extract 3rd place listings arrays configurations data
            let thirds = [];
            for (let gId in localStandings) {
                agg[localStandings[gId][0].name].groupWin++;
                thirds.push(localStandings[gId][2]);
            }
            thirds.sort((a, b) => {
                if (b.pts !== a.pts) return b.pts - a.pts;
                if (b.gd !== a.gd) return b.gd - a.gd;
                if (b.gf !== a.gf) return b.gf - a.gf;
                return (TEAM_METRICS[b.name]?.ELO || 0) - (TEAM_METRICS[a.name]?.ELO || 0);
            });

            let adv1 = []; let adv2 = []; let adv3 = [];
            for (let gId in localStandings) {
                adv1.push(localStandings[gId][0].name);
                adv2.push(localStandings[gId][1].name);
            }
            for (let i = 0; i < 8; i++) {
                if (thirds[i]) adv3.push(thirds[i].name);
            }

            // Record R32 metric occurrences values across structures
            adv1.forEach(t => agg[t].r32++);
            adv2.forEach(t => agg[t].r32++);
            adv3.forEach(t => agg[t].r32++);

            // Structure R32 active match list arrays setups
            let currentStageTeams = [];
            for (let i = 0; i < 16; i++) {
                currentStageTeams.push([adv1[i], i < 8 ? adv3[i] : adv2[i - 8]]);
            }

            // Execute Sequential Knock-out processing loops
            const stagesDefList = ["r16", "qf", "sf", "final", "trophy"];
            let activePairs = currentStageTeams;
            
            stagesDefList.forEach(stageKey => {
                let winnersList = [];
                activePairs.forEach(pair => {
                    let t1 = pair[0]; let t2 = pair[1];
                    let winner = t1;
                    if (!t1 && !t2) winner = null;
                    else if (!t1) winner = t2;
                    else if (!t2) winner = t1;
                    else {
                        let sim = runMatchSimulationCore(t1, t2, false, true);
                        winner = sim.winner;
                    }
                    if (winner) {
                        if (stageKey !== "trophy") {
                            agg[winner][stageKey]++;
                        } else {
                            agg[winner].trophy++;
                        }
                        winnersList.push(winner);
                    }
                });

                // Remap array definitions blocks setup for next loop pass
                if (stageKey !== "trophy") {
                    let nextPairs = [];
                    for (let k = 0; k < winnersList.length / 2; k++) {
                        nextPairs.push([winnersList[k * 2], winnersList[k * 2 + 1]]);
                    }
                    activePairs = nextPairs;
                }
            });
        }

        function sortAnalyticsData(columnKey) {
            if (currentSortColumn === columnKey) {
                currentSortDirection = currentSortDirection === "asc" ? "desc" : "asc";
            } else {
                currentSortColumn = columnKey;
                currentSortDirection = "desc";
            }
            sortAndRenderAnalyticsGrid();
        }

        function sortAndRenderAnalyticsGrid() {
            const filterText = document.getElementById("input-analytics-filter").value.toLowerCase();
            let data = [...globalAnalyticsCollection];
            
            // Filter logic
            if (filterText) {
                data = data.filter(item => item.team.toLowerCase().includes(filterText) || FIFA_CODES[item.team].toLowerCase().includes(filterText));
            }
            
            // Sort processing logic
            data.sort((a, b) => {
                let v1 = a[currentSortColumn];
                let v2 = b[currentSortColumn];
                if (typeof v1 === 'string') {
                    return currentSortDirection === "asc" ? v1.localeCompare(v2) : v2.localeCompare(v1);
                } else {
                    return currentSortDirection === "asc" ? v1 - v2 : v2 - v1;
                }
            });

            const tbody = document.querySelector("#analytics-table-target tbody");
            tbody.innerHTML = "";
            
            if (data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; color:var(--text-muted); padding:2rem;">No matching team portfolios discovered.</td></tr>`;
                return;
            }

            data.forEach(row => {
                tbody.innerHTML += `<tr>
                    <td class="team-cell" style="font-weight:600;">${getCountryFlagURLElement(row.team)} <span>${row.team} (${FIFA_CODES[row.team]})</span></td>
                    <td style="text-align:center; font-family:var(--font-mono);">${row.groupWin.toFixed(1)}%</td>
                    <td style="text-align:center; font-family:var(--font-mono);">${row.r32.toFixed(1)}%</td>
                    <td style="text-align:center; font-family:var(--font-mono);">${row.r16.toFixed(1)}%</td>
                    <td style="text-align:center; font-family:var(--font-mono);">${row.qf.toFixed(1)}%</td>
                    <td style="text-align:center; font-family:var(--font-mono);">${row.sf.toFixed(1)}%</td>
                    <td style="text-align:center; font-family:var(--font-mono);">${row.final.toFixed(1)}%</td>
                    <td style="font-weight:700; text-align:center; color:var(--accent-success); font-family:var(--font-mono);">
                        ${row.trophy.toFixed(1)}%
                        <div class="probability-bar-track"><div class="probability-bar-fill" style="width:${row.trophy}%; background-color:var(--accent-success);"></div></div>
                    </td>
                </tr>`;
            });
        }

        /* ==========================================================================
           9. LAYOUT SELECTION WINDOW CONTROLLER HANDLERS
           ========================================================================== */
        function switchActiveTab(event, tabId) {
            const panels = document.querySelectorAll(".main-content-canvas .tab-view-panel");
            panels.forEach(p => p.removeClassName = p.classList.remove("active"));
            
            const tabButtons = document.querySelectorAll(".tab-navigator-container .tab-button");
            tabButtons.forEach(btn => btn.classList.remove("active"));
            
            document.getElementById(tabId).classList.add("active");
            event.currentTarget.classList.add("active");

            // Contextual initialization maps overrides for pitch tab views
            if (tabId === "tab-tactical") {
                drawTacticalPlayerNodesOnPitch();
            }
        }

        function clearGlobalDataStatesPipeline() {
            manualScoreOverrides = {};
            injuryWardRegistry = {};
            suspensionWardRegistry = {};
            playerScoringRegistry = {};
            tournamentHasUpdatedState = false;
            
            document.getElementById("terminal-scroll-area-target").innerHTML = `<div style="color:var(--text-muted);">Terminal logs wiped. Storage registers normalized. Ready for calculation pass execution.</div>`;
            runMasterCalculationPipeline(false);
            
            const table_tbody = document.querySelector("#analytics-table-target tbody");
            table_tbody.innerHTML = `<tr><td colspan="8" style="text-align: center; color: var(--text-muted); padding: 2rem;">No analytics computed yet. Execute the stochastic loop engine to construct data mappings.</td></tr>`;
        }

        /* ==========================================================================
           10. INITIALIZATION CORES BINDINGS REGISTRATION
           ========================================================================== */
        function initializeApplicationCoreEngineListeners() {
            // Bind header triggers
            document.getElementById("btn-global-update").addEventListener("click", () => runMasterCalculationPipeline(false));
            document.getElementById("btn-global-simulate").addEventListener("click", () => {
                document.getElementById("terminal-scroll-area-target").innerHTML = "";
                appendTerminalLogMessage("🚀 INITIALIZING FULL SIMULATION PIPELINE RUN PASS...", "header");
                runMasterCalculationPipeline(true);
            });
            document.getElementById("btn-global-reset").addEventListener("click", clearGlobalDataStatesPipeline);
            
            // Bind analytic buttons
            document.getElementById("btn-run-analytics").addEventListener("click", triggerMonteCarloCalculationsPipeline);
            document.getElementById("input-analytics-filter").addEventListener("input", sortAndRenderAnalyticsGrid);
            document.getElementById("btn-clear-terminal").addEventListener("click", () => {
                document.getElementById("terminal-scroll-area-target").innerHTML = "";
            });

            // Populate blackboard configurations dropdown lists tags
            const selector = document.getElementById("select-tactical-team");
            Object.keys(TEAM_METRICS).sort().forEach(teamKey => {
                let opt = document.createElement("option");
                opt.value = teamKey;
                opt.innerText = `${teamKey} (${FIFA_CODES[teamKey] || "UN"})`;
                if (teamKey === "Spain") opt.selected = true;
                selector.appendChild(opt);
            });

            // Bind blackboard listeners parameters inputs elements change sequences
            selector.addEventListener("change", (e) => {
                activeTacticalTeamString = e.target.value;
                drawTacticalPlayerNodesOnPitch();
                syncTacticalSlidersAndCanvas();
            });
            document.getElementById("select-tactical-formation").addEventListener("change", drawTacticalPlayerNodesOnPitch);
            
            const slidersList = ["slider-aggression", "slider-tempo", "slider-depth"];
            slidersList.forEach(id => {
                document.getElementById(id).addEventListener("input", syncTacticalSlidersAndCanvas);
            });

            // Run first configuration layout compilation loops pass
            runMasterCalculationPipeline(false);
            syncTacticalSlidersAndCanvas();
        }

        // Defer instantiation execution tracking contexts to window ready states boundaries
        window.addEventListener("DOMContentLoaded", initializeApplicationCoreEngineListeners);
    </script>
