        /* ==========================================================================
           G. MONTE CARLO PROBABILITY STOCHASTIC aggregator LOOPS
           ========================================================================== */
        function executeMonteCarloStochasticLoopEngine(iterationsCountInput = 1000) {
            logSystemMessageText("montecarlo", `Initializing Stochastic Evaluation Engine Loops (${iterationsCountInput} rounds)...`, "info-type");
            cumulativeMonteCarloTallies = {};
            UNIQUE_48_TEAMS_LIST.forEach(t => cumulativeMonteCarloTallies[t] = 0);

            let currentLoopIndex = 0;
            const batchAllocationSteps = 100;
            
            function executionBatchSliceStep() {
                let limitBoundSlice = Math.min(iterationsCountInput - currentLoopIndex, batchAllocationSteps);
                for(let sliceIdx = 0; sliceIdx < limitBoundSlice; sliceIdx++) {
                    // Simulate full virtual environment parameters tracking models pathways maps
                    let sampleGroupsMatchesMap = {};
                    Object.keys(groupFixturesMatchMap).forEach(k => {
                        let originalMatch = groupFixturesMatchMap[k];
                        let res = calculatePoissonExpectancyGoalsProbabilities(originalMatch.t1, originalMatch.t2, false);
                        sampleGroupsMatchesMap[k] = { ...originalMatch, ...res, played: true };
                    });

                    // Build group standings matrices matching temporary run conditions values metrics
                    let virtualGroupsDefManifest = {};
                    Object.keys(groupsDefManifest).forEach(gKey => {
                        let originalG = groupsDefManifest[gKey];
                        let trackingMap = {};
                        originalG.teams.forEach(team => {
                            trackingMap[team] = { team: team, mp: 0, w: 0, d: 0, l: 0, gf: 0, ga: 0, gd: 0, pts: 0 };
                        });

                        ["M1", "M2", "M3"].forEach(mSubId => {
                            let m = sampleGroupsMatchesMap[`${gKey}-${mSubId}`];
                            let row1 = trackingMap[m.t1];
                            let row2 = trackingMap[m.t2];
                            row1.mp++; row2.mp++;
                            row1.gf += m.g1; row1.ga += m.g2;
                            row2.gf += m.g2; row2.ga += m.g1;
                            if(m.g1 > m.g2) { row1.w++; row1.pts += 3; row2.l++; }
                            else if(m.g2 > m.g1) { row2.w++; row2.pts += 3; row1.l++; }
                            else { row1.d++; row1.pts += 1; row2.d++; row2.pts += 1; }
                        });

                        Object.keys(trackingMap).forEach(t => trackingMap[t].gd = trackingMap[t].gf - trackingMap[t].ga);
                        virtualGroupsDefManifest[gKey] = {
                            standings: Object.values(trackingMap).sort((a,b) => {
                                if(b.pts !== a.pts) return b.pts - a.pts;
                                if(b.gd !== a.gd) return b.gd - a.gd;
                                return (TEAM_METRICS[b.team]?.elo || 0) - (TEAM_METRICS[a.team]?.elo || 0);
                            })
                        };
                    });

                    // Construct Round of 32 qualifiers
                    let virtualQualifiedList = [];
                    ["A","B","C","D","E","F","G","H","I","J","K","L","M","N","O","P"].forEach(gKey => {
                        virtualQualifiedList.push(virtualGroupsDefManifest[gKey].standings[0].team);
                        virtualQualifiedList.push(virtualGroupsDefManifest[gKey].standings[1].team);
                    });

                    // Execute knockout loop until single champion is resolved
                    let activeRoundTeams = [];
                    for(let i=0; i<16; i++) {
                        let res = calculatePoissonExpectancyGoalsProbabilities(virtualQualifiedList[i*2], virtualQualifiedList[(i*2+3)%32], true);
                        activeRoundTeams.push(res.winner);
                    }

                    const subRoundsCountsList = [8, 4, 2, 1];
                    subRoundsCountsList.forEach(rc => {
                        let nextRoundTeams = [];
                        for(let i=0; i<rc; i++) {
                            let res = calculatePoissonExpectancyGoalsProbabilities(activeRoundTeams[i*2], activeRoundTeams[i*2+1], true);
                            nextRoundTeams.push(res.winner);
                        }
                        activeRoundTeams = nextRoundTeams;
                    });

                    let loopFinalChampionString = activeRoundTeams[0];
                    if(cumulativeMonteCarloTallies[loopFinalChampionString] !== undefined) {
                        cumulativeMonteCarloTallies[loopFinalChampionString]++;
                    }
                    currentLoopIndex++;
                }

                logSystemMessageText("montecarlo", `Processed simulation iteration blocks count indices: ${currentLoopIndex}/${iterationsCountInput}`, "info-type");

                if(currentLoopIndex < iterationsCountInput) {
                    setTimeout(executionBatchSliceStep, 0);
                } else {
                    renderMonteCarloStochasticDistributionResultsTableHTMLDOM(iterationsCountInput);
                }
            }

            setTimeout(executionBatchSliceStep, 0);
        }

