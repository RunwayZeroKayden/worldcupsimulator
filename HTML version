                    { pos: "MF", left: 12, top: 48 }, { pos: "MF", left: 35, top: 52 }, { pos: "MF", left: 50, top: 55 }, { pos: "MF", left: 65, top: 52 }, { pos: "MF", left: 88, top: 48 },
