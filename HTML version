            const susp = document.getElementById("suspension-ward-target");
            susp.innerHTML = "";
            let suspKeys = Object.keys(suspensionWardRegistry);
            if (suspKeys.length === 0) {
                susp.innerHTML = `<li style="color:var(--text-muted); font-size:0.75rem;">No active player suspensions.</li>`;
            } else {
                suspKeys.forEach(p => {
                    susp.innerHTML += `<li class="ward-item-row"><b>${p}</b> <span style="color:var(--accent-warning); font-size:0.7rem;">Suspended</span></li>`;
                });
            }

            const goalsBlock = document.getElementById("top-scorers-target");
            goalsBlock.innerHTML = "";
            let sortedScorers = Object.entries(playerScoringRegistry).sort((a,b) => b[1] - a[1]).slice(0, 7);
            if (sortedScorers.length === 0) {
                goalsBlock.innerHTML = `<li style="color:var(--text-muted); font-size:0.75rem;">Awaiting simulation data...</li>`;
            } else {
                sortedScorers.forEach(item => {
                    goalsBlock.innerHTML += `<li class="ward-item-row"><span>${item[0]}</span> <b style="color:var(--accent-success);">${item[1]} Goals</b></li>`;
                });
            }
        }

        /* ==========================================================================
           7. INTERACTIVE TACTICAL BLACKBOARD PIPELINES
           ========================================================================== */
        function readBlackboardUIAttributes() {
            return {
                aggression: parseFloat(document.getElementById("slider-aggression").value),
                tempo: parseFloat(document.getElementById("slider-tempo").value),
                depth: parseFloat(document.getElementById("slider-depth").value)
            };
        }

        function syncTacticalSlidersAndCanvas() {
            document.getElementById("val-slider-aggression").innerText = document.getElementById("slider-aggression").value;
            document.getElementById("val-slider-tempo").innerText = document.getElementById("slider-tempo").value;
            document.getElementById("val-slider-depth").innerText = document.getElementById("slider-depth").value;
            
            const metrics = TEAM_METRICS[activeTacticalTeamString] || { ELO: 1500, PELE: 1500 };
            const settings = readBlackboardUIAttributes();
            
            // Calculate hypothetical adjustments derived from settings
            let attackFactor = (settings.tempo * 1.2 + settings.aggression * 0.8) / 100;
            let defenseFactor = (settings.depth * 1.5 + settings.aggression * 0.5) / 100;
            
            let mockOff = Math.round(metrics.PELE * attackFactor);
            let mockDef = Math.round(metrics.ELO / defenseFactor);
            
            const card = document.getElementById("tactical-metrics-output-card");
            card.innerHTML = `
                <div><strong>Adjusted Tactical Coefficients</strong></div>
                <div style="display:flex; justify-content:space-between; margin-top:4px;"><span>Offensive Value:</span><span style="color:var(--accent-success); font-weight:700;">${mockOff}</span></div>
                <div style="display:flex; justify-content:space-between;"><span>Defensive Stiffness:</span><span style="color:var(--accent-primary); font-weight:700;">${mockDef}</span></div>
            `;
        }

